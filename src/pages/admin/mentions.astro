<script>
  const ADMIN_PW = 'TEM-admin-2026!';
  const SB_URL = 'https://djtxbohjjpkhzhwlnrtu.supabase.co';
  const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRqdHhib2hqanBraHpod2xucnR1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwNDgzMjEsImV4cCI6MjA4NjYyNDMyMX0.UWgOz-9ZAy0xxVH-VTTysFzvrbD1CX0a459rNC391Hw';

  function sbH() { return { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' }; }
  async function sbGet(table: string, q = '') { const r = await fetch(`${SB_URL}/rest/v1/${table}?${q}`, { headers: sbH() }); if (!r.ok) throw new Error(await r.text()); return r.json(); }
  async function sbInsert(table: string, data: any) { const r = await fetch(`${SB_URL}/rest/v1/${table}`, { method: 'POST', headers: sbH(), body: JSON.stringify(data) }); if (!r.ok) throw new Error(await r.text()); return r.json(); }
  async function sbPatch(table: string, id: string, data: any) { const r = await fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'PATCH', headers: sbH(), body: JSON.stringify(data) }); if (!r.ok) throw new Error(await r.text()); return r.json(); }

  function sentBadge(s: string) {
    const m: any = { positive: 'badge-positive', neutral: 'badge-neutral', negative: 'badge-negative' };
    return `<span class="badge ${m[s]||'badge-neutral'}">${s||'neutral'}</span>`;
  }

  let allInsta: any[] = [];
  let allWeb: any[] = [];

  async function loadInsta() {
    const grid = document.getElementById('insta-grid')!;
    try {
      allInsta = await sbGet('instagram_mentions', 'order=post_date.desc');
      renderInsta();
    } catch(e) {
      grid.innerHTML = '<div class="empty">Error loading. Check instagram_mentions table exists.</div>';
    }
  }

  function renderInsta() {
    const grid = document.getElementById('insta-grid')!;
    const sentF = (document.getElementById('filter-insta-sentiment') as HTMLSelectElement).value;
    const actF = (document.getElementById('filter-insta-actioned') as HTMLSelectElement).value;
    let items = allInsta;
    if (sentF) items = items.filter(i => i.sentiment === sentF);
    if (actF !== '') items = items.filter(i => String(i.response_sent) === actF);
    if (!items.length) { grid.innerHTML = '<div class="empty">No Instagram mentions yet.</div>'; return; }
    grid.innerHTML = items.map(i => `
      <div class="insta-card">
        <div class="insta-card-header">
          <span class="insta-handle">${i.handle}</span>
          <span class="insta-date">${i.post_date||''}</span>
        </div>
        <div style="display:flex;gap:0.375rem;flex-wrap:wrap;margin-bottom:0.625rem">
          ${sentBadge(i.sentiment)}
          ${i.finish_mentioned ? `<span class="badge" style="background:#2a1a1a;color:#fca5a5">${i.finish_mentioned}</span>` : ''}
          ${i.response_sent ? '<span class="badge badge-actioned">Responded</span>' : ''}
        </div>
        ${i.caption_snippet ? `<div class="insta-caption">"${i.caption_snippet}"</div>` : ''}
        ${i.reach_estimate ? `<div class="insta-meta">Reach: ${i.reach_estimate}</div>` : ''}
        ${i.notes ? `<div class="insta-meta">${i.notes}</div>` : ''}
        <div class="insta-actions">
          ${i.post_url ? `<a href="${i.post_url}" target="_blank" class="btn-sm" style="display:inline-block">View Post</a>` : ''}
          ${!i.response_sent ? `<button class="btn-sm" onclick="markResponded('${i.id}')">Mark Responded</button>` : ''}
        </div>
      </div>
    `).join('');
  }

  (window as any).markResponded = async function(id: string) {
    await sbPatch('instagram_mentions', id, { response_sent: true, actioned: true });
    loadInsta();
  };

  async function loadWeb() {
    const tbody = document.getElementById('web-tbody')!;
    const empty = document.getElementById('web-empty')!;
    try {
      allWeb = await sbGet('web_mentions', 'order=published_date.desc');
      renderWeb();
    } catch(e) {
      empty.textContent = 'Error loading. Check web_mentions table exists.';
      empty.style.display = 'block';
    }
  }

  function renderWeb() {
    const tbody = document.getElementById('web-tbody')!;
    const empty = document.getElementById('web-empty')!;
    const typeF = (document.getElementById('filter-web-type') as HTMLSelectElement).value;
    const sentF = (document.getElementById('filter-web-sentiment') as HTMLSelectElement).value;
    let items = allWeb;
    if (typeF) items = items.filter(i => i.mention_type === typeF);
    if (sentF) items = items.filter(i => i.sentiment === sentF);
    if (!items.length) { tbody.innerHTML = ''; empty.textContent = 'No web mentions yet.'; empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    tbody.innerHTML = items.map(i => `
      <tr>
        <td><a href="${i.source_url||'#'}" target="_blank">${i.source_name}</a></td>
        <td style="max-width:240px">${i.title||'—'}</td>
        <td><span class="badge badge-type">${(i.mention_type||'').replace(/_/g,' ')}</span></td>
        <td>${sentBadge(i.sentiment)}</td>
        <td>${i.backlink ? '<span class="badge badge-backlink">Yes</span>' : '<span style="color:#555">No</span>'}</td>
        <td style="color:#888">${i.da_estimate||'—'}</td>
        <td style="color:#666;white-space:nowrap">${i.published_date||'—'}</td>
        <td><button class="btn-sm" onclick="markWebActioned('${i.id}')" ${i.actioned ? 'disabled style="opacity:0.4"' : ''}>${i.actioned ? 'Done' : 'Action'}</button></td>
      </tr>
    `).join('');
  }

  (window as any).markWebActioned = async function(id: string) {
    await sbPatch('web_mentions', id, { actioned: true });
    loadWeb();
  };

  (window as any).copyAlert = function(text: string) {
    navigator.clipboard.writeText(text);
  };

  // Filters
  ['filter-insta-sentiment','filter-insta-actioned'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderInsta);
  });
  ['filter-web-type','filter-web-sentiment'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderWeb);
  });

  // Instagram modal
  document.getElementById('add-insta-btn')!.addEventListener('click', () => { document.getElementById('insta-modal')!.style.display = 'flex'; });
  document.getElementById('cancel-insta-btn')!.addEventListener('click', () => { document.getElementById('insta-modal')!.style.display = 'none'; });
  document.getElementById('save-insta-btn')!.addEventListener('click', async () => {
    const handle = (document.getElementById('im-handle') as HTMLInputElement).value.trim();
    if (!handle) { alert('Handle required'); return; }
    await sbInsert('instagram_mentions', {
      handle,
      post_url: (document.getElementById('im-url') as HTMLInputElement).value || null,
      post_date: (document.getElementById('im-date') as HTMLInputElement).value || null,
      caption_snippet: (document.getElementById('im-caption') as HTMLTextAreaElement).value || null,
      finish_mentioned: (document.getElementById('im-finish') as HTMLInputElement).value || null,
      reach_estimate: (document.getElementById('im-reach') as HTMLInputElement).value || null,
      sentiment: (document.getElementById('im-sentiment') as HTMLSelectElement).value,
      response_sent: (document.getElementById('im-responded') as HTMLSelectElement).value === 'true',
      notes: (document.getElementById('im-notes') as HTMLTextAreaElement).value || null,
    });
    document.getElementById('insta-modal')!.style.display = 'none';
    loadInsta();
  });

  // Web mention modal
  document.getElementById('add-web-btn')!.addEventListener('click', () => { document.getElementById('web-modal')!.style.display = 'flex'; });
  document.getElementById('cancel-web-btn')!.addEventListener('click', () => { document.getElementById('web-modal')!.style.display = 'none'; });
  document.getElementById('save-web-btn')!.addEventListener('click', async () => {
    const source = (document.getElementById('wm-source') as HTMLInputElement).value.trim();
    if (!source) { alert('Source name required'); return; }
    await sbInsert('web_mentions', {
      source_name: source,
      source_url: (document.getElementById('wm-url') as HTMLInputElement).value || null,
      title: (document.getElementById('wm-title') as HTMLInputElement).value || null,
      published_date: (document.getElementById('wm-date') as HTMLInputElement).value || null,
      mention_type: (document.getElementById('wm-type') as HTMLSelectElement).value,
      sentiment: (document.getElementById('wm-sentiment') as HTMLSelectElement).value,
      da_estimate: parseInt((document.getElementById('wm-da') as HTMLInputElement).value) || null,
      backlink: (document.getElementById('wm-backlink') as HTMLSelectElement).value === 'true',
      snippet: (document.getElementById('wm-snippet') as HTMLTextAreaElement).value || null,
    });
    document.getElementById('web-modal')!.style.display = 'none';
    loadWeb();
  });

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const tab = (e.currentTarget as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      document.getElementById(`tab-${tab}`)!.classList.add('active');
      if (tab === 'web') loadWeb();
    });
  });

  // Auth
  const gate = document.getElementById('gate')!;
  const app = document.getElementById('app')!;
  const pwInput = document.getElementById('pw-input') as HTMLInputElement;
  function tryLogin(pw: string) {
    if (pw === ADMIN_PW) {
      sessionStorage.setItem('tem-admin-password', pw);
      gate.style.display = 'none';
      app.style.display = 'block';
      loadInsta();
    } else {
      const e = document.getElementById('pw-error')!;
      e.textContent = 'Invalid password';
      e.style.display = 'block';
    }
  }
  if (sessionStorage.getItem('tem-admin-password') === ADMIN_PW) { gate.style.display = 'none'; app.style.display = 'block'; loadInsta(); }
  document.getElementById('pw-btn')!.addEventListener('click', () => tryLogin(pwInput.value));
  pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(pwInput.value); });
  document.getElementById('logout-btn')!.addEventListener('click', () => { sessionStorage.removeItem('tem-admin-password'); gate.style.display = 'flex'; app.style.display = 'none'; });
</script>
</body>
</html>
