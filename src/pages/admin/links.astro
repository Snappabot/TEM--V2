              <option value="pr_mention">PR Mention</option>
              <option value="directory">Directory</option>
              <option value="partnership">Partnership</option>
              <option value="resource_link">Resource Link</option>
            </select>
          </div>
          <div class="form-group">
            <label>Contact Name</label>
            <input id="or-contact-name" type="text" placeholder="Editor name" />
          </div>
          <div class="form-group">
            <label>Contact Email</label>
            <input id="or-contact-email" type="email" placeholder="editor@site.com" />
          </div>
          <div class="form-group">
            <label>Pitch Date</label>
            <input id="or-date" type="date" />
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="or-status">
              <option value="planned">Planned</option>
              <option value="sent">Sent</option>
              <option value="follow_up">Follow Up</option>
              <option value="won">Won</option>
              <option value="lost">Lost</option>
              <option value="no_reply">No Reply</option>
            </select>
          </div>
          <div class="form-group full">
            <label>Notes</label>
            <textarea id="or-notes" rows="2" placeholder="Pitch angle, contact context..."></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-add" id="or-save">Save Prospect</button>
          <button class="btn-sm" onclick="document.getElementById('add-outreach-modal').style.display='none'">Cancel</button>
        </div>
      </div>
    </div>

    <!-- EDIT STATUS MODAL -->
    <div id="edit-outreach-modal" class="modal-overlay" style="display:none">
      <div class="modal">
        <button class="modal-close" onclick="document.getElementById('edit-outreach-modal').style.display='none'">&#215;</button>
        <h3 id="edit-or-title">Edit Outreach</h3>
        <input type="hidden" id="edit-or-id" />
        <div class="form-grid">
          <div class="form-group">
            <label>Status</label>
            <select id="edit-or-status">
              <option value="planned">Planned</option>
              <option value="sent">Sent</option>
              <option value="follow_up">Follow Up</option>
              <option value="won">Won</option>
              <option value="lost">Lost</option>
              <option value="no_reply">No Reply</option>
            </select>
          </div>
          <div class="form-group">
            <label>DA/DR</label>
            <input type="number" id="edit-or-da" placeholder="50" min="0" max="100" />
          </div>
          <div class="form-group full">
            <label>Notes</label>
            <textarea id="edit-or-notes" rows="3"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-add" id="edit-or-save">Update</button>
          <button class="btn-danger" id="edit-or-delete">Delete</button>
          <button class="btn-sm" onclick="document.getElementById('edit-outreach-modal').style.display='none'">Cancel</button>
        </div>
      </div>
    </div>

    <!-- ADD DIRECTORY MODAL -->
    <div id="add-dir-modal" class="modal-overlay" style="display:none">
      <div class="modal">
        <button class="modal-close" onclick="document.getElementById('add-dir-modal').style.display='none'">&#215;</button>
        <h3>Add Directory</h3>
        <div class="form-grid">
          <div class="form-group full">
            <label>Directory Name</label>
            <input id="dir-name" type="text" placeholder="Directory name" />
          </div>
          <div class="form-group full">
            <label>URL</label>
            <input id="dir-url" type="text" placeholder="https://..." />
          </div>
          <div class="form-group">
            <label>Category</label>
            <input id="dir-category" type="text" placeholder="e.g. Trade Directory" />
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="dir-status">
              <option value="not_submitted">Not Submitted</option>
              <option value="pending">Pending</option>
              <option value="live">Live</option>
            </select>
          </div>
          <div class="form-group">
            <label>Submitted Date</label>
            <input id="dir-submitted-date" type="date" />
          </div>
          <div class="form-group full">
            <label>Listing URL (once live)</label>
            <input id="dir-listing-url" type="text" placeholder="https://..." />
          </div>
          <div class="form-group full">
            <label>Notes</label>
            <textarea id="dir-notes" rows="2"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-add" id="dir-save">Save Directory</button>
          <button class="btn-sm" onclick="document.getElementById('add-dir-modal').style.display='none'">Cancel</button>
        </div>
      </div>
    </div>

    <script>
    const SUPABASE_URL = 'https://djtxbohjjpkhzhwlnrtu.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRqdHhib2hqanBraHpod2xucnR1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwNDgzMjEsImV4cCI6MjA4NjYyNDMyMX0.UWgOz-9ZAy0xxVH-VTTysFzvrbD1CX0a459rNC391Hw';
    const ADMIN_PW = 'TEM-admin-2026!';

    async function sbFetch(path, opts = {}) {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
        headers: {
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${SUPABASE_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': opts.prefer || 'return=representation',
          ...opts.headers
        },
        ...opts
      });
      if (!res.ok && res.status !== 204) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || res.statusText);
      }
      return res.status === 204 ? null : res.json();
    }

    // ── AUTH ──────────────────────────────────────────────────────────
    const loginSection = document.getElementById('login-section');
    const dashSection  = document.getElementById('dashboard-section');
    const pwInput      = document.getElementById('admin-password');
    const loginErr     = document.getElementById('login-error');

    function unlock() {
      loginSection.style.display = 'none';
      dashSection.style.display  = 'block';
      initAll();
    }

    const stored = sessionStorage.getItem('tem-admin-pw');
    if (stored === ADMIN_PW) unlock();

    document.getElementById('login-btn').addEventListener('click', () => {
      if (pwInput.value === ADMIN_PW) {
        sessionStorage.setItem('tem-admin-pw', pwInput.value);
        loginErr.style.display = 'none';
        unlock();
      } else {
        loginErr.textContent = 'Incorrect password.';
        loginErr.style.display = 'block';
      }
    });
    pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('login-btn').click(); });
    document.getElementById('logout-btn').addEventListener('click', () => {
      sessionStorage.removeItem('tem-admin-pw');
      location.reload();
    });

    // ── DATA ──────────────────────────────────────────────────────────
    let outreachData = [];
    let dirData = [];
    let backlinkData = [];
    let velocityChart = null;

    const SEED_OUTREACH = [
      { target_site:'Sanctuary Magazine',                             site_url:'https://www.sanctuarymagazine.org.au', da_dr:45, pitch_type:'pr_mention',   status:'planned', notes:'Sustainability/eco homes editorial mention' },
      { target_site:'ArchDaily Australia',                            site_url:'https://www.archdaily.com',            da_dr:87, pitch_type:'guest_post',   status:'planned', notes:'Product feature / project case study' },
      { target_site:'Architecture & Design AU',                       site_url:'https://www.architectureanddesign.com.au', da_dr:55, pitch_type:'pr_mention', status:'planned', notes:'Editorial pitch' },
      { target_site:'ArchiPro AU',                                    site_url:'https://archipro.com.au',              da_dr:48, pitch_type:'directory',     status:'planned', notes:'Business listing + project portfolio' },
      { target_site:'Houzz AU',                                       site_url:'https://www.houzz.com.au',             da_dr:82, pitch_type:'directory',     status:'planned', notes:'Business listing + project photos' },
      { target_site:'The Fifth Estate',                               site_url:'https://thefifthestate.com.au',        da_dr:52, pitch_type:'pr_mention',   status:'planned', notes:'Sustainable building news mention' },
      { target_site:'Green Building Council Australia',               site_url:'https://www.gbca.org.au',              da_dr:68, pitch_type:'directory',     status:'planned', notes:'Member directory / mention' },
      { target_site:'Renew Magazine',                                 site_url:'https://renew.org.au',                 da_dr:49, pitch_type:'guest_post',   status:'planned', notes:'Hemp render feature article' },
      { target_site:'HIA (Housing Industry Association)',             site_url:'https://hia.com.au',                   da_dr:61, pitch_type:'directory',     status:'planned', notes:'Member directory' },
      { target_site:'Realestate.com.au Renovations',                 site_url:'https://www.realestate.com.au',        da_dr:90, pitch_type:'resource_link', status:'planned', notes:'Project feature' },
    ];

    const SEED_DIRS = [
      { directory_name:'ArchiPro AU',                url:'https://archipro.com.au',             category:'Architectural Products', status:'not_submitted' },
      { directory_name:'Houzz AU',                   url:'https://www.houzz.com.au',             category:'Home Improvement',       status:'not_submitted' },
      { directory_name:'Google Business Profile',    url:'https://business.google.com',          category:'Local Business',         status:'not_submitted' },
      { directory_name:'True Local',                 url:'https://www.truelocal.com.au',         category:'Local Business',         status:'not_submitted' },
      { directory_name:'hipages',                    url:'https://hipages.com.au',               category:'Trade Services',         status:'not_submitted' },
      { directory_name:'Seek a Trade',               url:'https://www.seekatrade.com.au',        category:'Trade Services',         status:'not_submitted' },
      { directory_name:'Product Review',             url:'https://www.productreview.com.au',     category:'Reviews',                status:'not_submitted' },
      { directory_name:'Yellow Pages AU',            url:'https://www.yellowpages.com.au',       category:'General Business',       status:'not_submitted' },
      { directory_name:'Yelp AU',                    url:'https://www.yelp.com.au',              category:'General Business',       status:'not_submitted' },
      { directory_name:'GBCA Member Directory',      url:'https://new.gbca.org.au',              category:'Industry Association',   status:'not_submitted' },
      { directory_name:'HIA Member Directory',       url:'https://hia.com.au',                   category:'Industry Association',   status:'not_submitted' },
      { directory_name:'Master Builders AU',         url:'https://www.masterbuilders.com.au',    category:'Industry Association',   status:'not_submitted' },
    ];

    async function initAll() {
      try {
        outreachData = await sbFetch('link_outreach?order=created_at.asc') || [];
        if (outreachData.length === 0) await seedOutreach();
      } catch(e) { await seedOutreach().catch(() => { outreachData = SEED_OUTREACH.map((s,i)=>({...s,id:'seed-'+i})); }); }

      try {
        dirData = await sbFetch('directory_submissions?order=created_at.asc') || [];
        if (dirData.length === 0) await seedDirs();
      } catch(e) { await seedDirs().catch(() => { dirData = SEED_DIRS.map((s,i)=>({...s,id:'seed-'+i})); }); }

      try {
        backlinkData = await sbFetch('backlinks?order=first_seen.asc') || [];
      } catch(e) { backlinkData = []; }

      renderGoals();
      renderKanban();
      renderDirs();
      renderChart();
    }

    async function seedOutreach() {
      try {
        const rows = await sbFetch('link_outreach', { method:'POST', body: JSON.stringify(SEED_OUTREACH) });
        outreachData = rows || SEED_OUTREACH.map((s,i)=>({...s,id:'seed-'+i}));
      } catch(e) { outreachData = SEED_OUTREACH.map((s,i)=>({...s,id:'seed-'+i})); }
    }

    async function seedDirs() {
      try {
        const rows = await sbFetch('directory_submissions', { method:'POST', body: JSON.stringify(SEED_DIRS) });
        dirData = rows || SEED_DIRS.map((s,i)=>({...s,id:'seed-'+i}));
      } catch(e) { dirData = SEED_DIRS.map((s,i)=>({...s,id:'seed-'+i})); }
    }

    // ── GOALS ─────────────────────────────────────────────────────────
    function getQuarterStart() {
      const now = new Date();
      const q = Math.floor(now.getMonth() / 3);
      return new Date(now.getFullYear(), q * 3, 1);
    }

    function renderGoals() {
      const target = parseInt(document.getElementById('goal-target').value) || 5;
      const qStart = getQuarterStart();
      const earned = outreachData.filter(o => {
        if (o.status !== 'won') return false;
        if (!o.pitch_date) return true;
        return new Date(o.pitch_date) >= qStart;
      }).length;
      const total  = outreachData.length;
      const sent   = outreachData.filter(o => ['sent','follow_up','won','lost'].includes(o.status)).length;
      const replied = outreachData.filter(o => ['won','lost'].includes(o.status)).length;
      const rate = sent > 0 ? Math.round((replied / sent) * 100) + '%' : '—';

      document.getElementById('goal-earned').textContent = earned;
      document.getElementById('goal-total-outreach').textContent = total;
      document.getElementById('goal-response-rate').textContent = rate;
      document.getElementById('goal-bar').style.width = `${Math.min((earned/target)*100,100)}%`;
    }

    function updateGoal() { renderGoals(); }
    window.updateGoal = updateGoal;

    // ── KANBAN ────────────────────────────────────────────────────────
    const KANBAN_COLS = [
      { key:'planned',   label:'Planned' },
      { key:'sent',      label:'Sent' },
      { key:'follow_up', label:'Follow Up' },
      { key:'won',       label:'Won' },
      { key:'lost',      label:'Lost' },
      { key:'no_reply',  label:'No Reply' },
    ];

    const PITCH_LABELS = { guest_post:'Guest Post', pr_mention:'PR Mention', directory:'Directory', partnership:'Partnership', resource_link:'Resource Link' };

    function renderKanban() {
      const board = document.getElementById('kanban-board');
      board.innerHTML = KANBAN_COLS.map(col => {
        const cards = outreachData.filter(o => o.status === col.key);
        return `<div class="kanban-col col-${col.key}">
          <div class="kanban-col-header">
            <span class="kanban-col-title">${col.label}</span>
            <span class="kanban-col-count">${cards.length}</span>
          </div>
          <div class="kanban-cards">
            ${cards.map(o => `
              <div class="kanban-card" onclick="openEditOutreach('${o.id}')">
                <div class="kc-site">${o.target_site}</div>
                ${o.da_dr ? `<div class="kc-meta">DA/DR ~${o.da_dr}</div>` : ''}
                <div><span class="kc-type">${PITCH_LABELS[o.pitch_type]||o.pitch_type||'—'}</span></div>
              </div>`).join('')}
          </div>
        </div>`;
      }).join('');
    }

    function openEditOutreach(id) {
      const o = outreachData.find(x => x.id === id);
      if (!o) return;
      document.getElementById('edit-or-id').value    = id;
      document.getElementById('edit-or-title').textContent = o.target_site;
      document.getElementById('edit-or-status').value = o.status;
      document.getElementById('edit-or-da').value     = o.da_dr || '';
      document.getElementById('edit-or-notes').value  = o.notes || '';
      document.getElementById('edit-outreach-modal').style.display = 'flex';
    }
    window.openEditOutreach = openEditOutreach;

    document.getElementById('edit-or-save').addEventListener('click', async () => {
      const id     = document.getElementById('edit-or-id').value;
      const status = document.getElementById('edit-or-status').value;
      const da_dr  = parseInt(document.getElementById('edit-or-da').value) || null;
      const notes  = document.getElementById('edit-or-notes').value;
      try {
        await sbFetch(`link_outreach?id=eq.${id}`, { method:'PATCH', body: JSON.stringify({ status, da_dr, notes }) });
        const idx = outreachData.findIndex(o => o.id === id);
        if (idx !== -1) outreachData[idx] = { ...outreachData[idx], status, da_dr, notes };
      } catch(e) {
        const idx = outreachData.findIndex(o => o.id === id);
        if (idx !== -1) outreachData[idx] = { ...outreachData[idx], status, da_dr, notes };
      }
      document.getElementById('edit-outreach-modal').style.display = 'none';
      renderGoals(); renderKanban();
    });

    document.getElementById('edit-or-delete').addEventListener('click', async () => {
      const id = document.getElementById('edit-or-id').value;
      if (!confirm('Delete this prospect?')) return;
      try { await sbFetch(`link_outreach?id=eq.${id}`, { method:'DELETE', prefer:'return=minimal' }); } catch(e) {}
      outreachData = outreachData.filter(o => o.id !== id);
      document.getElementById('edit-outreach-modal').style.display = 'none';
      renderGoals(); renderKanban();
    });

    document.getElementById('or-save').addEventListener('click', async () => {
      const item = {
        target_site:   document.getElementById('or-site').value.trim(),
        site_url:      document.getElementById('or-url').value,
        da_dr:         parseInt(document.getElementById('or-da').value) || null,
        pitch_type:    document.getElementById('or-pitch-type').value,
        contact_name:  document.getElementById('or-contact-name').value,
        contact_email: document.getElementById('or-contact-email').value,
        pitch_date:    document.getElementById('or-date').value || null,
        status:        document.getElementById('or-status').value,
        notes:         document.getElementById('or-notes').value,
      };
      if (!item.target_site) return alert('Target site required.');
      try {
        const rows = await sbFetch('link_outreach', { method:'POST', body: JSON.stringify([item]) });
        outreachData.push(rows && rows[0] ? rows[0] : { ...item, id:'local-'+Date.now() });
      } catch(e) { outreachData.push({ ...item, id:'local-'+Date.now() }); }
      document.getElementById('add-outreach-modal').style.display = 'none';
      renderGoals(); renderKanban();
    });

    // ── DIRECTORIES ───────────────────────────────────────────────────
    function renderDirs() {
      const tbody = document.getElementById('dir-tbody');
      const statusBadge = s => {
        const map = { not_submitted:'badge-not_submitted', pending:'badge-pending', live:'badge-live' };
        const label = { not_submitted:'Not Submitted', pending:'Pending', live:'Live' };
        return `<span class="badge ${map[s]||'badge-not_submitted'}">${label[s]||s}</span>`;
      };
      tbody.innerHTML = dirData.map(d => `
        <tr>
          <td style="color:#e5e7eb;font-weight:500">${d.directory_name}</td>
          <td style="color:#6b7280;font-size:0.8rem">${d.category||'—'}</td>
          <td>
            <select style="padding:0.2rem 0.4rem;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:4px;color:#fff;font-size:0.8rem;outline:none"
              onchange="updateDirStatus('${d.id}',this.value)">
              <option value="not_submitted" ${d.status==='not_submitted'?'selected':''}>Not Submitted</option>
              <option value="pending" ${d.status==='pending'?'selected':''}>Pending</option>
              <option value="live" ${d.status==='live'?'selected':''}>Live</option>
            </select>
          </td>
          <td style="color:#6b7280;font-size:0.8rem">${d.submitted_date||'—'}</td>
          <td style="font-size:0.8rem">${d.listing_url ? `<a href="${d.listing_url}" target="_blank" style="color:#8b7355">${d.listing_url.replace('https://','').slice(0,30)}…</a>` : '—'}</td>
          <td><button class="btn-danger" onclick="deleteDir('${d.id}')">Delete</button></td>
        </tr>`).join('');
    }

    async function updateDirStatus(id, status) {
      const today = new Date().toISOString().split('T')[0];
      const patch = { status, ...(status !== 'not_submitted' ? { submitted_date: today } : {}) };
      try { await sbFetch(`directory_submissions?id=eq.${id}`, { method:'PATCH', body: JSON.stringify(patch) }); } catch(e) {}
      const idx = dirData.findIndex(d => d.id === id);
      if (idx !== -1) dirData[idx] = { ...dirData[idx], ...patch };
    }
    window.updateDirStatus = updateDirStatus;

    async function deleteDir(id) {
      if (!confirm('Remove this directory?')) return;
      try { await sbFetch(`directory_submissions?id=eq.${id}`, { method:'DELETE', prefer:'return=minimal' }); } catch(e) {}
      dirData = dirData.filter(d => d.id !== id);
      renderDirs();
    }
    window.deleteDir = deleteDir;

    document.getElementById('dir-save').addEventListener('click', async () => {
      const item = {
        directory_name: document.getElementById('dir-name').value.trim(),
        url:            document.getElementById('dir-url').value,
        category:       document.getElementById('dir-category').value,
        status:         document.getElementById('dir-status').value,
        submitted_date: document.getElementById('dir-submitted-date').value || null,
        listing_url:    document.getElementById('dir-listing-url').value,
        notes:          document.getElementById('dir-notes').value,
      };
      if (!item.directory_name) return alert('Directory name required.');
      try {
        const rows = await sbFetch('directory_submissions', { method:'POST', body: JSON.stringify([item]) });
        dirData.push(rows && rows[0] ? rows[0] : { ...item, id:'local-'+Date.now() });
      } catch(e) { dirData.push({ ...item, id:'local-'+Date.now() }); }
      document.getElementById('add-dir-modal').style.display = 'none';
      renderDirs();
    });

    // ── CHART ─────────────────────────────────────────────────────────
    function renderChart() {
      const canvas = document.getElementById('velocity-chart');
      const empty  = document.getElementById('chart-empty');

      if (!backlinkData.length) {
        canvas.style.display = 'none';
        empty.style.display  = 'block';
        return;
      }

      const monthMap = {};
      const lostMap  = {};
      backlinkData.forEach(b => {
        if (b.first_seen) {
          const m = b.first_seen.slice(0, 7);
          monthMap[m] = (monthMap[m]||0) + 1;
        }
        if (b.status === 'lost' && b.last_checked) {
          const m = b.last_checked.slice(0, 7);
          lostMap[m] = (lostMap[m]||0) + 1;
        }
      });

      const allMonths = [...new Set([...Object.keys(monthMap), ...Object.keys(lostMap)])].sort();
      if (!allMonths.length) { canvas.style.display='none'; empty.style.display='block'; return; }

      if (velocityChart) velocityChart.destroy();
      velocityChart = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: allMonths,
          datasets: [
            {
              label: 'Links Gained',
              data: allMonths.map(m => monthMap[m]||0),
              backgroundColor: '#8b735580',
              borderColor: '#8b7355',
              borderWidth: 1,
            },
            {
              label: 'Links Lost',
              data: allMonths.map(m => -(lostMap[m]||0)),
              backgroundColor: '#7f1d1d80',
              borderColor: '#ef4444',
              borderWidth: 1,
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            x: { ticks: { color:'#6b7280', font:{size:11} }, grid: { color:'#1a1a1a' } },
            y: { ticks: { color:'#6b7280', font:{size:11} }, grid: { color:'#1a1a1a' } }
          },
          plugins: {
            legend: { labels: { color:'#9ca3af', font:{size:12} } }
          }
        }
      });
    }
    </script>
  </body>
</html>
