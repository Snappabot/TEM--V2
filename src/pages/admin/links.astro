            <label>Target Site</label>
            <input id="or-site" type="text" placeholder="Sanctuary Magazine" />
          </div>
          <div class="form-group full">
            <label>Site URL</label>
            <input id="or-url" type="text" placeholder="https://..." />
          </div>
          <div class="form-group">
            <label>DA/DR Estimate</label>
            <input id="or-da" type="number" placeholder="50" min="0" max="100" />
          </div>
          <div class="form-group">
            <label>Pitch Type</label>
            <select id="or-pitch-type">
