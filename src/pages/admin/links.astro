---
export const prerender = false;
---

<!--
  SQL MIGRATIONS — run in Supabase SQL editor before using this page:

  create table if not exists link_outreach (
    id uuid primary key default gen_random_uuid(),
    target_site text not null,
    site_url text,
    da_dr int,
    contact_name text,
    contact_email text,
    pitch_type text check (pitch_type in ('guest_post','pr_mention','directory','partnership','resource_link')),
    pitch_date date,
    status text not null default 'planned' check (status in ('planned','sent','follow_up','won','lost','no_reply')),
    notes text,
    created_at timestamptz default now()
  );

  create table if not exists directory_submissions (
    id uuid primary key default gen_random_uuid(),
    directory_name text not null,
    url text,
    category text,
    submitted_date date,
    status text not null default 'not_submitted' check (status in ('not_submitted','pending','live')),
    listing_url text,
    notes text,
    created_at timestamptz default now()
  );

  -- backlinks table (shared with analytics page):
  create table if not exists backlinks (
    id uuid primary key default gen_random_uuid(),
    source_url text not null,
    target_url text,
    anchor_text text,
    da_dr int,
    first_seen date,
    last_checked date,
    status text default 'active' check (status in ('active','lost','pending')),
    notes text,
    created_at timestamptz default now()
  );
-->

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Link Building Tracker | Troweled Earth</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #0a0a0a; color: #fff; min-height: 100vh; }
      input, select, textarea { font-family: inherit; }

      /* Login */
      .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 1rem; }
      .login-card { width: 100%; max-width: 380px; }
      .login-card h1 { font-size: 1.75rem; font-weight: 300; text-align: center; margin-bottom: 2rem; color: #fff; }
      .login-card input { width: 100%; padding: 0.875rem 1rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px; color: #fff; font-size: 1rem; outline: none; }
      .login-card input:focus { border-color: #8b7355; }
      .btn-primary { display: block; width: 100%; padding: 0.875rem; margin-top: 0.75rem; background: #8b7355; color: #fff; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; transition: background 0.2s; }
      .btn-primary:hover { background: #a68b6a; }
      .error-msg { color: #f87171; font-size: 0.8rem; margin-top: 0.5rem; }

      /* Header */
      .dash-header { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; border-bottom: 1px solid #1a1a1a; flex-wrap: wrap; gap: 0.75rem; }
      .dash-header h1 { font-size: 1.25rem; font-weight: 400; }
      .dash-header .logo { color: #8b7355; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; }
      .dash-nav { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
      .dash-nav a { padding: 0.4rem 0.875rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: all 0.2s; }
      .dash-nav a:hover { border-color: #8b7355; color: #fff; }
      .dash-nav a.active { border-color: #8b7355; color: #8b7355; }
      .btn-sm { padding: 0.5rem 1rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #9ca3af; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
      .btn-sm:hover { border-color: #8b7355; color: #fff; }
      .btn-add { padding: 0.5rem 1.25rem; background: #8b7355; border: none; border-radius: 6px; color: #fff; font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: background 0.2s; }
      .btn-add:hover { background: #a68b6a; }
      .btn-danger { padding: 0.3rem 0.6rem; background: transparent; border: 1px solid #7f1d1d; border-radius: 4px; color: #f87171; font-size: 0.75rem; cursor: pointer; }
      .btn-danger:hover { background: #7f1d1d; color: #fff; }

      .dash-body { max-width: 1400px; margin: 0 auto; padding: 2rem; }

      /* Panels */
      .panel { background: #111; border: 1px solid #1a1a1a; border-radius: 10px; padding: 1.5rem; margin-bottom: 2rem; }
      .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem; }
      .panel-header h2 { font-size: 1rem; font-weight: 500; color: #e5e7eb; }
      .section-heading { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #8b7355; margin-bottom: 0.5rem; }

      /* Goal dashboard */
      .goal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
      .goal-card { background: #0f0f0f; border: 1px solid #1a1a1a; border-radius: 8px; padding: 1.25rem; }
      .goal-card .g-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; margin-bottom: 0.5rem; }
      .goal-card .g-value { font-size: 1.75rem; font-weight: 600; color: #fff; }
      .goal-card .g-sub { font-size: 0.75rem; color: #6b7280; margin-top: 0.25rem; }
      .goal-card.highlight { border-color: #8b7355; }
      .goal-card.highlight .g-value { color: #8b7355; }
      .progress-bar { width: 100%; height: 6px; background: #1a1a1a; border-radius: 3px; margin-top: 0.75rem; overflow: hidden; }
      .progress-fill { height: 100%; background: #8b7355; border-radius: 3px; transition: width 0.4s; }
      .editable-goal { display: flex; align-items: center; gap: 0.5rem; }
      .editable-goal input { width: 60px; padding: 0.3rem 0.5rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 4px; color: #fff; font-size: 1rem; font-weight: 600; outline: none; }
      .editable-goal input:focus { border-color: #8b7355; }

      /* Forms */
      .form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
      .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
      .form-group.full { grid-column: 1 / -1; }
      .form-group label { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em; }
      .form-group input, .form-group select, .form-group textarea { padding: 0.6rem 0.875rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #fff; font-size: 0.9rem; outline: none; }
      .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #8b7355; }
      .form-group select option { background: #1a1a1a; }
      .form-actions { display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap; }

      /* Kanban */
      .kanban { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
      .kanban-col { background: #0f0f0f; border: 1px solid #1a1a1a; border-radius: 8px; overflow: hidden; }
      .kanban-col-header { padding: 0.75rem 1rem; border-bottom: 1px solid #1a1a1a; display: flex; align-items: center; justify-content: space-between; }
      .kanban-col-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
      .kanban-col-count { font-size: 0.7rem; color: #6b7280; background: #1a1a1a; border-radius: 999px; padding: 0.1rem 0.4rem; }
      .kanban-cards { padding: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; min-height: 60px; }
      .kanban-card { background: #111; border: 1px solid #1a1a1a; border-radius: 6px; padding: 0.75rem; cursor: pointer; transition: border-color 0.2s; }
      .kanban-card:hover { border-color: #2a2a2a; }
      .kc-site { font-size: 0.85rem; font-weight: 500; color: #e5e7eb; }
      .kc-meta { font-size: 0.72rem; color: #6b7280; margin-top: 0.25rem; }
      .kc-type { display: inline-block; margin-top: 0.35rem; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.65rem; background: #1a1a1a; border: 1px solid #2a2a2a; color: #9ca3af; }
      .col-planned .kanban-col-header { border-top: 2px solid #4b5563; }
      .col-sent .kanban-col-header { border-top: 2px solid #1e3a5f; }
      .col-follow_up .kanban-col-header { border-top: 2px solid #3a2a00; }
      .col-won .kanban-col-header { border-top: 2px solid #14532d; }
      .col-lost .kanban-col-header { border-top: 2px solid #7f1d1d; }
      .col-no_reply .kanban-col-header { border-top: 2px solid #374151; }
      .col-planned .kanban-col-title { color: #9ca3af; }
      .col-sent .kanban-col-title { color: #93c5fd; }
      .col-follow_up .kanban-col-title { color: #fde68a; }
      .col-won .kanban-col-title { color: #86efac; }
      .col-lost .kanban-col-title { color: #fca5a5; }
      .col-no_reply .kanban-col-title { color: #6b7280; }

      /* Directory table */
      .table-wrap { overflow-x: auto; }
      table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
      thead tr { border-bottom: 1px solid #1a1a1a; }
      th { padding: 0.75rem 1rem; text-align: left; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; white-space: nowrap; }
      td { padding: 0.75rem 1rem; border-bottom: 1px solid #111; vertical-align: middle; }
      tr:hover td { background: #0f0f0f; }
      .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.7rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
      .badge-not_submitted { background: #1a1a1a; color: #6b7280; border: 1px solid #2a2a2a; }
      .badge-pending { background: #3a2a00; color: #fde68a; }
      .badge-live { background: #14532d; color: #86efac; }
      .empty-state { text-align: center; padding: 3rem; color: #4b5563; }

      /* Chart */
      .chart-wrap { position: relative; height: 220px; }

      /* Modal */
      .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; align-items: center; justify-content: center; z-index: 50; padding: 1rem; }
      .modal { background: #111; border: 1px solid #1a1a1a; border-radius: 10px; padding: 1.5rem; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; }
      .modal h3 { font-size: 1rem; font-weight: 500; margin-bottom: 1.25rem; color: #e5e7eb; }
      .modal-close { float: right; background: none; border: none; color: #6b7280; font-size: 1.25rem; cursor: pointer; line-height: 1; }

      @media (max-width: 640px) {
        .dash-header { padding: 1rem; }
        .dash-body { padding: 1rem; }
        .kanban { grid-template-columns: 1fr; }
        .goal-grid { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <!-- LOGIN GATE -->
    <div id="login-section" class="login-wrap">
      <div class="login-card">
        <h1>Link Building Tracker</h1>
        <input type="password" id="admin-password" placeholder="Admin password" autocomplete="current-password" />
        <p id="login-error" class="error-msg" style="display:none"></p>
        <button class="btn-primary" id="login-btn">Enter</button>
      </div>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard-section" style="display:none">
      <header class="dash-header">
        <div>
          <div class="logo">Troweled Earth Melbourne</div>
          <h1>Link Building &amp; Off-Page SEO</h1>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
          <nav class="dash-nav">
            <a href="/admin/campaigns">Campaigns</a>
            <a href="/admin/strategy">Strategy</a>
            <a href="/admin/content">Content</a>
            <a href="/admin/links" class="active">Links</a>
          </nav>
          <button class="btn-sm" id="logout-btn">Log out</button>
        </div>
      </header>

      <div class="dash-body">

        <!-- ── 1. BACKLINK GOALS ───────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Off-Page KPIs</div>
          <div class="panel-header">
            <h2>Backlink Goals Dashboard</h2>
            <button class="btn-sm" onclick="document.getElementById('add-outreach-modal').style.display='flex'">+ Add Outreach</button>
          </div>
          <div class="goal-grid">
            <div class="goal-card highlight">
              <div class="g-label">Quarterly Goal</div>
              <div class="editable-goal">
                <input type="number" id="goal-target" value="5" min="1" max="99" onchange="updateGoal()" />
                <span style="color:#6b7280;font-size:0.85rem">high-DA links</span>
              </div>
              <div class="g-sub">Target per quarter</div>
            </div>
            <div class="goal-card">
              <div class="g-label">Earned This Quarter</div>
              <div class="g-value" id="goal-earned">0</div>
              <div class="g-sub">Won outreach entries</div>
              <div class="progress-bar"><div class="progress-fill" id="goal-bar" style="width:0%"></div></div>
            </div>
            <div class="goal-card">
              <div class="g-label">Total Outreach</div>
              <div class="g-value" id="goal-total-outreach">0</div>
              <div class="g-sub">All prospects logged</div>
            </div>
            <div class="goal-card">
              <div class="g-label">Response Rate</div>
              <div class="g-value" id="goal-response-rate">—</div>
              <div class="g-sub">Won + Lost / Sent</div>
            </div>
          </div>
        </div>

        <!-- ── 2. OUTREACH KANBAN ─────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Prospect Pipeline</div>
          <div class="panel-header">
            <h2>Outreach Log</h2>
          </div>
          <div class="kanban" id="kanban-board">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- ── 3. DIRECTORY SUBMISSIONS ──────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Citation Building</div>
          <div class="panel-header">
            <h2>Directory Submissions Tracker</h2>
            <button class="btn-sm" onclick="document.getElementById('add-dir-modal').style.display='flex'">+ Add Directory</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Directory</th>
                  <th>Category</th>
                  <th>Status</th>
                  <th>Submitted</th>
                  <th>Listing URL</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="dir-tbody"></tbody>
            </table>
          </div>
        </div>

        <!-- ── 4. LINK VELOCITY CHART ─────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Link Acquisition</div>
          <div class="panel-header">
            <h2>Link Velocity</h2>
