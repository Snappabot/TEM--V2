      { question: 'What is the best natural plaster finish for Melbourne homes?',   intent:'commercial',    source:'manual', priority:'high' },
      { question: 'Is hemp render better than cement render?',                       intent:'informational', source:'manual', priority:'high' },
      { question: 'How much does venetian plaster cost in Melbourne?',               intent:'commercial',    source:'manual', priority:'high' },
      { question: 'What is marbellino plaster?',                                     intent:'informational', source:'manual', priority:'medium' },
      { question: 'Can you use hemp render in a bathroom?',                          intent:'informational', source:'manual', priority:'medium' },
      { question: 'What is carbon sequestering render?',                             intent:'informational', source:'manual', priority:'high' },
      { question: 'How do I find a certified natural plaster applicator in Melbourne?', intent:'navigational', source:'manual', priority:'high' },
      { question: 'What is the difference between lime render and cement render?',   intent:'informational', source:'manual', priority:'medium' },
      { question: 'Is tadelakt suitable for Australian bathrooms?',                  intent:'informational', source:'manual', priority:'medium' },
      { question: 'How long does decorative plaster last?',                          intent:'informational', source:'manual', priority:'medium' },
      { question: 'What is the most breathable wall render?',                        intent:'informational', source:'manual', priority:'medium' },
      { question: 'Can hemp render be used in new builds in Australia?',             intent:'informational', source:'manual', priority:'high' },
      { question: 'What does NCC 2022 say about wall renders?',                      intent:'informational', source:'manual', priority:'medium' },
      { question: 'How do I maintain venetian plaster walls?',                       intent:'informational', source:'manual', priority:'low' },
      { question: 'What plaster finishes are best for passive houses?',              intent:'commercial',    source:'manual', priority:'high' },
      { question: 'How much CO\u2082 does hemp render sequester?',                   intent:'informational', source:'manual', priority:'high' },
      { question: 'What is concretum finish?',                                       intent:'informational', source:'manual', priority:'low' },
      { question: 'How do I choose between microcement and plaster?',                intent:'commercial',    source:'manual', priority:'medium' },
      { question: 'Where can I see hemp render examples in Melbourne?',              intent:'navigational',  source:'manual', priority:'medium' },
      { question: 'What training is available for natural plaster finishes?',        intent:'commercial',    source:'manual', priority:'medium' },
    ];

    async function seedTopics() {
      try {
        const rows = await sbFetch('content_topics', { method: 'POST', body: JSON.stringify(SEED_TOPICS) });
        topics = rows || SEED_TOPICS.map((s,i) => ({ ...s, id: 'seed-'+i }));
      } catch(e) { topics = SEED_TOPICS.map((s,i) => ({ ...s, id: 'seed-'+i })); }
    }

    let topicFilter = 'all';
    function renderTopics() {
      const tbody = document.getElementById('topics-tbody');
      const empty = document.getElementById('topics-empty');
      let filtered = topics;
      if (topicFilter === 'high') filtered = topics.filter(t => t.priority === 'high');
      else if (['informational','commercial','navigational'].includes(topicFilter)) {
        filtered = topics.filter(t => t.intent === topicFilter);
      }

      const intentBadge = i => {
        const map = { informational:'badge-info', commercial:'badge-commercial', navigational:'badge-nav' };
        return `<span class="badge ${map[i]||'badge-draft'}">${i}</span>`;
      };
      const prioBadge = p => {
        const map = { high:'badge-high', medium:'badge-medium', low:'badge-low' };
        return `<span class="badge ${map[p]||'badge-draft'}">${p}</span>`;
      };

      if (!filtered.length) {
        tbody.innerHTML = '';
        empty.style.display = 'block';
        return;
      }
      empty.style.display = 'none';
      tbody.innerHTML = filtered.map(t => `
        <tr>
          <td style="max-width:320px;color:#e5e7eb">${t.question}</td>
          <td>${intentBadge(t.intent)}</td>
          <td style="color:#6b7280;font-size:0.8rem">${t.source}</td>
          <td>${prioBadge(t.priority)}</td>
          <td style="color:#6b7280;font-size:0.8rem">${t.assigned_to_content_id ? '<span style="color:#86efac">&#10003; Assigned</span>' : '—'}</td>
          <td><button class="btn-sm" onclick="deleteTopic('${t.id}')">Delete</button></td>
        </tr>`).join('');
    }

    document.getElementById('topic-filters').addEventListener('click', e => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      topicFilter = btn.dataset.filter;
      renderTopics();
    });

    async function deleteTopic(id) {
      if (!confirm('Delete this topic?')) return;
      try {
        await sbFetch(`content_topics?id=eq.${id}`, { method: 'DELETE', prefer: 'return=minimal' });
        topics = topics.filter(t => t.id !== id);
      } catch(e) { topics = topics.filter(t => t.id !== id); }
      renderTopics();
    }

    const topicModal = document.getElementById('topic-modal');
    document.getElementById('add-topic-btn').addEventListener('click', () => { topicModal.style.display = 'flex'; });
    document.getElementById('topic-modal-close').addEventListener('click', () => { topicModal.style.display = 'none'; });
    document.getElementById('tm-cancel').addEventListener('click', () => { topicModal.style.display = 'none'; });

    document.getElementById('tm-save').addEventListener('click', async () => {
      const topic = {
        question: document.getElementById('tm-question').value.trim(),
        intent:   document.getElementById('tm-intent').value,
        source:   document.getElementById('tm-source').value,
        priority: document.getElementById('tm-priority').value,
        notes:    document.getElementById('tm-notes').value,
      };
      if (!topic.question) return alert('Question required.');
      try {
        const rows = await sbFetch('content_topics', { method: 'POST', body: JSON.stringify([topic]) });
        topics.push(rows && rows[0] ? rows[0] : { ...topic, id: 'local-'+Date.now() });
      } catch(e) { topics.push({ ...topic, id: 'local-'+Date.now() }); }
      topicModal.style.display = 'none';
      renderTopics();
    });

    // Seed calendar if empty
    (async () => {
      if (typeof initAll === 'function') return; // deferred to initAll
    })();

    // Override initAll to check cal seed
    const _origInit = initAll;
    window.initAll = async function() {
      const now = new Date();
      calYear = now.getFullYear();
      calMonth = now.getMonth();

      try { contentPages = await sbFetch('content_pages?order=created_at.asc') || []; } catch(e) { contentPages = []; }

      try {
        calendarItems = await sbFetch('content_calendar?order=publish_date.asc') || [];
        if (calendarItems.length === 0) await seedCalendar();
      } catch(e) { await seedCalendar().catch(() => {}); }

      try {
        topics = await sbFetch('content_topics?order=created_at.asc') || [];
        if (topics.length === 0) await seedTopics();
      } catch(e) { topics = []; await seedTopics().catch(() => {}); }

      renderPillars();
      renderCalendar();
      initChecklists();
      renderTopics();
    };

    window.togglePillar  = togglePillar;
    window.toggleCluster = toggleCluster;
    window.saveCluster   = saveCluster;
    window.toggleCheck   = toggleCheck;
    window.deleteTopic   = deleteTopic;
    </script>
  </body>
</html>
