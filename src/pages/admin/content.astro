---
export const prerender = false;
---

<!--
  SQL MIGRATIONS — run in Supabase SQL editor before using this page:

  create table if not exists content_pages (
    id uuid primary key default gen_random_uuid(),
    type text not null check (type in ('pillar','cluster')),
    pillar_id uuid references content_pages(id) on delete cascade,
    title text not null,
    target_keyword text,
    status text not null default 'Draft' check (status in ('Draft','In Progress','Published','Optimising')),
    page_url text,
    word_count int,
    published_date date,
    last_updated date,
    notes text,
    created_at timestamptz default now()
  );

  create table if not exists content_calendar (
    id uuid primary key default gen_random_uuid(),
    title text not null,
    content_type text not null check (content_type in ('blog','reel','case_study','pr_release','social','email')),
    channel text,
    publish_date date not null,
    status text not null default 'planned' check (status in ('planned','in_progress','review','published')),
    assigned_to text,
    notes text,
    campaign_id text,
    created_at timestamptz default now()
  );

  create table if not exists content_topics (
    id uuid primary key default gen_random_uuid(),
    question text not null,
    intent text not null check (intent in ('informational','commercial','navigational')),
    source text not null check (source in ('GSC','customer','competitor','manual')),
    priority text not null default 'medium' check (priority in ('high','medium','low')),
    assigned_to_content_id uuid,
    notes text,
    created_at timestamptz default now()
  );
-->

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Strategy Hub | Troweled Earth</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #0a0a0a; color: #fff; min-height: 100vh; }
      input, select, textarea { font-family: inherit; }

      /* Login */
      .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 1rem; }
      .login-card { width: 100%; max-width: 380px; }
      .login-card h1 { font-size: 1.75rem; font-weight: 300; text-align: center; margin-bottom: 2rem; color: #fff; }
      .login-card input { width: 100%; padding: 0.875rem 1rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px; color: #fff; font-size: 1rem; outline: none; }
      .login-card input:focus { border-color: #8b7355; }
      .btn-primary { display: block; width: 100%; padding: 0.875rem; margin-top: 0.75rem; background: #8b7355; color: #fff; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; transition: background 0.2s; }
      .btn-primary:hover { background: #a68b6a; }
      .error-msg { color: #f87171; font-size: 0.8rem; margin-top: 0.5rem; }

      /* Header */
      .dash-header { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; border-bottom: 1px solid #1a1a1a; flex-wrap: wrap; gap: 0.75rem; }
      .dash-header h1 { font-size: 1.25rem; font-weight: 400; }
      .dash-header .logo { color: #8b7355; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; }
      .dash-nav { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
      .dash-nav a { padding: 0.4rem 0.875rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: all 0.2s; }
      .dash-nav a:hover { border-color: #8b7355; color: #fff; }
      .dash-nav a.active { border-color: #8b7355; color: #8b7355; }
      .btn-sm { padding: 0.5rem 1rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #9ca3af; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
      .btn-sm:hover { border-color: #8b7355; color: #fff; }

      .dash-body { max-width: 1400px; margin: 0 auto; padding: 2rem; }

      /* Panels */
      .panel { background: #111; border: 1px solid #1a1a1a; border-radius: 10px; padding: 1.5rem; margin-bottom: 2rem; }
      .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem; }
      .panel-header h2 { font-size: 1rem; font-weight: 500; color: #e5e7eb; }
      .section-heading { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #8b7355; margin-bottom: 0.5rem; }

      /* Forms */
      .form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
      .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
      .form-group.full { grid-column: 1 / -1; }
      .form-group label { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em; }
      .form-group input, .form-group select, .form-group textarea { padding: 0.6rem 0.875rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #fff; font-size: 0.9rem; outline: none; }
      .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #8b7355; }
      .form-group select option { background: #1a1a1a; }
      .form-actions { display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap; }
      .btn-add { padding: 0.5rem 1.25rem; background: #8b7355; border: none; border-radius: 6px; color: #fff; font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: background 0.2s; }
      .btn-add:hover { background: #a68b6a; }

      /* Badges */
      .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.65rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
      .badge-draft { background: #1a1a1a; color: #9ca3af; border: 1px solid #2a2a2a; }
      .badge-in-progress { background: #1e3a5f; color: #93c5fd; }
      .badge-published { background: #14532d; color: #86efac; }
      .badge-optimising { background: #3a1a00; color: #fbbf24; }

      /* Pillar/Cluster tree */
      .pillar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 1.5rem; }
      .pillar-card { background: #0f0f0f; border: 1px solid #8b7355; border-radius: 10px; overflow: hidden; }
      .pillar-card-header { padding: 1.25rem; cursor: pointer; display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; }
      .pillar-card-header:hover { background: #111; }
      .pillar-icon { width: 2rem; height: 2rem; background: #8b735520; border: 1px solid #8b7355; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; color: #8b7355; flex-shrink: 0; }
      .pillar-info { flex: 1; }
      .pillar-title { font-size: 0.95rem; font-weight: 600; color: #e5e7eb; }
      .pillar-keyword { font-size: 0.75rem; color: #8b7355; margin-top: 0.2rem; font-style: italic; }
      .pillar-meta { display: flex; gap: 0.5rem; align-items: center; margin-top: 0.5rem; flex-wrap: wrap; }
      .pillar-chevron { font-size: 0.75rem; color: #4b5563; transition: transform 0.25s; flex-shrink: 0; }
      .pillar-card.open .pillar-chevron { transform: rotate(180deg); }
      .pillar-detail { display: none; border-top: 1px solid #1a1a1a; }
      .pillar-card.open .pillar-detail { display: block; }
      .pillar-fields { padding: 1rem 1.25rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; background: #111; }
      .field-group { display: flex; flex-direction: column; gap: 0.3rem; }
      .field-group label { font-size: 0.65rem; color: #4b5563; text-transform: uppercase; letter-spacing: 0.08em; }
      .field-group input, .field-group select, .field-group textarea { padding: 0.45rem 0.75rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 5px; color: #fff; font-size: 0.82rem; outline: none; }
      .field-group input:focus, .field-group select:focus, .field-group textarea:focus { border-color: #8b7355; }
      .field-group.span2 { grid-column: 1 / -1; }
      .cluster-list { padding: 0.75rem 1.25rem 1.25rem; background: #0f0f0f; }
      .cluster-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #4b5563; margin-bottom: 0.75rem; }
      .cluster-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.875rem; background: #111; border: 1px solid #1a1a1a; border-radius: 6px; margin-bottom: 0.5rem; cursor: pointer; transition: border-color 0.2s; }
      .cluster-item:hover { border-color: #2a2a2a; }
      .cluster-item.open { border-color: #8b735540; }
      .cluster-dot { width: 6px; height: 6px; border-radius: 50%; background: #8b7355; flex-shrink: 0; }
      .cluster-title { font-size: 0.85rem; color: #d1d5db; flex: 1; }
      .cluster-expand { display: none; padding: 0.75rem 0.875rem 0.875rem; background: #0a0a0a; border: 1px solid #1a1a1a; border-top: none; border-radius: 0 0 6px 6px; margin-top: -0.5rem; margin-bottom: 0.5rem; }
      .cluster-item.open + .cluster-expand { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
      .save-btn { padding: 0.3rem 0.75rem; background: #8b7355; border: none; border-radius: 4px; color: #fff; font-size: 0.75rem; cursor: pointer; margin-top: 0.5rem; }
      .save-btn:hover { background: #a68b6a; }

      /* Calendar */
      .cal-nav { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
      .cal-nav button { padding: 0.35rem 0.75rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 5px; color: #9ca3af; cursor: pointer; font-size: 0.85rem; }
      .cal-nav button:hover { border-color: #8b7355; color: #fff; }
      .cal-month-title { font-size: 1rem; font-weight: 500; color: #e5e7eb; min-width: 160px; text-align: center; }
      .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: #1a1a1a; border: 1px solid #1a1a1a; border-radius: 8px; overflow: hidden; }
      .cal-day-header { background: #0f0f0f; padding: 0.5rem; text-align: center; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; }
      .cal-day { background: #0a0a0a; min-height: 90px; padding: 0.4rem; vertical-align: top; }
      .cal-day.other-month { background: #080808; }
      .cal-day.today { background: #0f1a0f; }
      .cal-date { font-size: 0.7rem; color: #6b7280; margin-bottom: 0.3rem; }
      .cal-day.today .cal-date { color: #86efac; font-weight: 600; }
      .cal-item { margin-bottom: 2px; padding: 0.15rem 0.35rem; border-radius: 3px; font-size: 0.65rem; line-height: 1.3; cursor: pointer; }
      .cal-item.blog { background: #1e3a5f; color: #93c5fd; }
      .cal-item.reel { background: #3a1a3a; color: #d8b4fe; }
      .cal-item.case_study { background: #14532d; color: #86efac; }
      .cal-item.pr_release { background: #3a2a00; color: #fde68a; }
      .cal-item.social { background: #1a3a3a; color: #67e8f9; }
      .cal-item.email { background: #3a1a1a; color: #fca5a5; }
      .cal-summary { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; padding: 0.875rem 1rem; background: #0f0f0f; border: 1px solid #1a1a1a; border-radius: 8px; }
      .cal-sum-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; }
      .cal-sum-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
      .cal-sum-dot.blog { background: #93c5fd; }
      .cal-sum-dot.reel { background: #d8b4fe; }
      .cal-sum-dot.case_study { background: #86efac; }
      .cal-sum-dot.pr_release { background: #fde68a; }
      .cal-sum-dot.social { background: #67e8f9; }
      .cal-sum-dot.email { background: #fca5a5; }

      /* Modal */
      .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; align-items: center; justify-content: center; z-index: 50; padding: 1rem; }
      .modal { background: #111; border: 1px solid #1a1a1a; border-radius: 10px; padding: 1.5rem; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto; }
      .modal h3 { font-size: 1rem; font-weight: 500; margin-bottom: 1.25rem; color: #e5e7eb; }
      .modal-close { float: right; background: none; border: none; color: #6b7280; font-size: 1.25rem; cursor: pointer; line-height: 1; }

      /* Checklists */
      .checklist { display: flex; flex-direction: column; gap: 0.5rem; }
      .check-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.75rem 1rem; background: #0f0f0f; border: 1px solid #1a1a1a; border-radius: 6px; cursor: pointer; transition: border-color 0.2s; }
      .check-item:hover { border-color: #2a2a2a; }
      .check-item.checked { border-color: #14532d; background: #0a150a; }
      .check-box { width: 18px; height: 18px; border: 1.5px solid #2a2a2a; border-radius: 4px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; transition: all 0.15s; }
      .check-item.checked .check-box { background: #14532d; border-color: #14532d; }
      .check-tick { display: none; color: #86efac; font-size: 0.7rem; }
      .check-item.checked .check-tick { display: block; }
      .check-text { font-size: 0.85rem; color: #9ca3af; line-height: 1.5; }
      .check-item.checked .check-text { color: #4b5563; text-decoration: line-through; }
      .checklist-progress { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
      .progress-bar { flex: 1; height: 4px; background: #1a1a1a; border-radius: 2px; overflow: hidden; }
      .progress-fill { height: 100%; background: #8b7355; border-radius: 2px; transition: width 0.3s; }
      .progress-label { font-size: 0.75rem; color: #6b7280; white-space: nowrap; }

      /* Topics table */
      .table-wrap { overflow-x: auto; }
      table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
      thead tr { border-bottom: 1px solid #1a1a1a; }
      th { padding: 0.75rem 1rem; text-align: left; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; white-space: nowrap; }
      td { padding: 0.75rem 1rem; border-bottom: 1px solid #111; vertical-align: middle; }
      tr:hover td { background: #0f0f0f; }
      .badge-high { background: #3a0a0a; color: #fca5a5; border: 1px solid #7f1d1d; }
      .badge-medium { background: #1e3a5f; color: #93c5fd; border: 1px solid #1e3a5f; }
      .badge-low { background: #1a1a1a; color: #6b7280; border: 1px solid #2a2a2a; }
      .badge-info { background: #14532d; color: #86efac; }
      .badge-commercial { background: #3a1a00; color: #fbbf24; }
      .badge-nav { background: #1a3a3a; color: #67e8f9; }
      .empty-state { text-align: center; padding: 3rem; color: #4b5563; }
      .filter-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
      .filter-btn { padding: 0.3rem 0.75rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 999px; color: #9ca3af; font-size: 0.75rem; cursor: pointer; transition: all 0.2s; }
      .filter-btn.active { border-color: #8b7355; color: #8b7355; }

      @media (max-width: 640px) {
        .dash-header { padding: 1rem; }
        .dash-body { padding: 1rem; }
        .pillar-grid { grid-template-columns: 1fr; }
        .cal-grid { grid-template-columns: repeat(7, minmax(40px, 1fr)); font-size: 0.6rem; }
        .cal-day { min-height: 60px; }
      }
    </style>
  </head>
  <body>
    <!-- LOGIN GATE -->
    <div id="login-section" class="login-wrap">
      <div class="login-card">
        <h1>Content Strategy Hub</h1>
        <input type="password" id="admin-password" placeholder="Admin password" autocomplete="current-password" />
        <p id="login-error" class="error-msg" style="display:none"></p>
        <button class="btn-primary" id="login-btn">Enter</button>
      </div>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard-section" style="display:none">
      <header class="dash-header">
        <div>
          <div class="logo">Troweled Earth Melbourne</div>
          <h1>Content Strategy Hub</h1>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
          <nav class="dash-nav">
            <a href="/admin/campaigns">Campaigns</a>
            <a href="/admin/strategy">Strategy</a>
            <a href="/admin/content" class="active">Content</a>
            <a href="/admin/links">Links</a>
          </nav>
          <button class="btn-sm" id="logout-btn">Log out</button>
        </div>
      </header>

      <div class="dash-body">

        <!-- ── 1. PILLAR & CLUSTER MAP ─────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Content Architecture</div>
          <div class="panel-header">
            <h2>Pillar &amp; Cluster Content Map</h2>
            <button class="btn-sm" id="save-all-btn">Save All Changes</button>
          </div>
          <div class="pillar-grid" id="pillar-grid">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- ── 2. CONTENT CALENDAR ────────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Editorial Planning</div>
          <div class="panel-header">
            <h2>Content Calendar</h2>
            <button class="btn-sm" id="add-cal-btn">+ Add Item</button>
          </div>
          <div class="cal-nav">
            <button id="cal-prev">&#8592;</button>
            <div class="cal-month-title" id="cal-title"></div>
            <button id="cal-next">&#8594;</button>
          </div>
          <div class="cal-grid" id="cal-grid">
            <!-- Rendered by JS -->
          </div>
          <div class="cal-summary" id="cal-summary"></div>
        </div>

        <!-- ── 3. E-E-A-T CHECKLIST ──────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Trust Signals</div>
          <div class="panel-header">
            <h2>E-E-A-T Checklist</h2>
          </div>
          <div class="checklist-progress">
            <div class="progress-bar"><div class="progress-fill" id="eeat-fill" style="width:0%"></div></div>
            <div class="progress-label" id="eeat-label">0 / 10</div>
          </div>
          <div class="checklist" id="eeat-list"></div>
        </div>

        <!-- ── 4. AI SEARCH CHECKLIST ────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">GEO / AIO</div>
          <div class="panel-header">
            <h2>AI Search Optimisation Checklist</h2>
          </div>
          <div class="checklist-progress">
            <div class="progress-bar"><div class="progress-fill" id="aio-fill" style="width:0%"></div></div>
            <div class="progress-label" id="aio-label">0 / 10</div>
          </div>
          <div class="checklist" id="aio-list"></div>
        </div>

        <!-- ── 5. TOPIC RESEARCH BANK ─────────────────────────────────── -->
        <div class="panel">
          <div class="section-heading">Keyword Research</div>
          <div class="panel-header">
            <h2>Topic Research Bank</h2>
            <button class="btn-sm" id="add-topic-btn">+ Add Topic</button>
          </div>
          <div class="filter-row" id="topic-filters">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="high">High Priority</button>
            <button class="filter-btn" data-filter="informational">Informational</button>
            <button class="filter-btn" data-filter="commercial">Commercial</button>
            <button class="filter-btn" data-filter="navigational">Navigational</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Question</th>
                  <th>Intent</th>
                  <th>Source</th>
                  <th>Priority</th>
                  <th>Assigned</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="topics-tbody"></tbody>
            </table>
          </div>
          <div id="topics-empty" class="empty-state" style="display:none">No topics yet. Add some research questions above.</div>
        </div>

      </div><!-- /dash-body -->
    </div><!-- /dashboard-section -->

    <!-- CALENDAR ADD MODAL -->
    <div id="cal-modal" class="modal-overlay" style="display:none">
      <div class="modal">
        <button class="modal-close" id="cal-modal-close">&#215;</button>
        <h3 id="cal-modal-title">Add Calendar Item</h3>
        <div class="form-grid">
          <div class="form-group full">
            <label>Title</label>
            <input id="cm-title" type="text" placeholder="Content title" />
          </div>
          <div class="form-group">
            <label>Content Type</label>
            <select id="cm-type">
              <option value="blog">Blog Post</option>
              <option value="reel">Instagram Reel</option>
              <option value="case_study">Case Study</option>
              <option value="pr_release">PR Release</option>
              <option value="social">Social Post</option>
              <option value="email">Email Newsletter</option>
            </select>
          </div>
          <div class="form-group">
            <label>Channel</label>
            <input id="cm-channel" type="text" placeholder="e.g. Instagram, Blog" />
          </div>
          <div class="form-group">
            <label>Publish Date</label>
            <input id="cm-date" type="date" />
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="cm-status">
              <option value="planned">Planned</option>
              <option value="in_progress">In Progress</option>
              <option value="review">Review</option>
              <option value="published">Published</option>
            </select>
          </div>
          <div class="form-group">
            <label>Assigned To</label>
            <input id="cm-assigned" type="text" placeholder="e.g. Matt" />
          </div>
          <div class="form-group full">
            <label>Notes</label>
            <textarea id="cm-notes" rows="2" placeholder="Optional notes..."></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-add" id="cm-save">Save Item</button>
