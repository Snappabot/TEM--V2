    function renderCalendar() {
      const title = document.getElementById('cal-title');
      const grid  = document.getElementById('cal-grid');
      const sumEl = document.getElementById('cal-summary');

      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      title.textContent = `${monthNames[calMonth]} ${calYear}`;

      const firstDay = new Date(calYear, calMonth, 1).getDay();
      const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
      const today = new Date();
      const todayStr = fmt(today);

      let html = DAYS.map(d => `<div class="cal-day-header">${d}</div>`).join('');

      for (let i = 0; i < firstDay; i++) {
        const prevDate = new Date(calYear, calMonth, -firstDay + i + 1);
        html += `<div class="cal-day other-month"><div class="cal-date">${prevDate.getDate()}</div></div>`;
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const isToday = dateStr === todayStr;
        const dayItems = calendarItems.filter(it => it.publish_date === dateStr);
        html += `<div class="cal-day${isToday?' today':''}">
          <div class="cal-date">${d}</div>
          ${dayItems.map(it => `<div class="cal-item ${it.content_type}" title="${it.title}">${it.title.length > 22 ? it.title.slice(0,22)+'…' : it.title}</div>`).join('')}
        </div>`;
      }

      const totalCells = firstDay + daysInMonth;
      const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
      for (let i = 1; i <= remaining; i++) {
        html += `<div class="cal-day other-month"><div class="cal-date">${i}</div></div>`;
      }

      grid.innerHTML = html;

      // Summary
      const monthItems = calendarItems.filter(it => {
        const d = new Date(it.publish_date);
        return d.getFullYear() === calYear && d.getMonth() === calMonth;
      });
      const counts = {};
      monthItems.forEach(it => { counts[it.content_type] = (counts[it.content_type]||0)+1; });
      sumEl.innerHTML = Object.entries(counts).length
        ? Object.entries(counts).map(([type, cnt]) =>
            `<div class="cal-sum-item"><div class="cal-sum-dot ${type}"></div><span style="color:#9ca3af">${TYPE_LABELS[type]||type}:</span><strong>${cnt}</strong></div>`
          ).join('')
        : '<span style="color:#4b5563;font-size:0.8rem">No items this month.</span>';
    }

