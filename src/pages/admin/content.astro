    function renderChecklist(prefix, items, fillId, labelId) {
      const list = document.getElementById(`${prefix}-list`);
      list.innerHTML = items.map((text, i) => {
        const checked = !!localStorage.getItem(`check-${prefix}-${i}`);
        return `<div class="check-item${checked?' checked':''}" onclick="toggleCheck('${prefix}',${i},${items.length},'${fillId}','${labelId}')">
          <div class="check-box"><span class="check-tick">&#10003;</span></div>
          <div class="check-text">${text}</div>
        </div>`;
      }).join('');
      updateProgress(prefix, items.length, fillId, labelId);
    }

    function refreshChecklist(prefix, items, fillId, labelId) {
      const list = document.getElementById(`${prefix}-list`);
      items.forEach((_, i) => {
        const el = list.children[i];
        if (!el) return;
        const checked = !!localStorage.getItem(`check-${prefix}-${i}`);
        el.classList.toggle('checked', checked);
      });
      updateProgress(prefix, items.length, fillId, labelId);
    }

    function toggleCheck(prefix, i, total, fillId, labelId) {
      const key = `check-${prefix}-${i}`;
      if (localStorage.getItem(key)) localStorage.removeItem(key);
      else localStorage.setItem(key, '1');
      const list = document.getElementById(`${prefix}-list`);
      const el = list.children[i];
      if (el) el.classList.toggle('checked', !!localStorage.getItem(key));
      updateProgress(prefix, total, fillId, labelId);
    }

    function updateProgress(prefix, total, fillId, labelId) {
      let done = 0;
      for (let i = 0; i < total; i++) { if (localStorage.getItem(`check-${prefix}-${i}`)) done++; }
      document.getElementById(fillId).style.width = `${(done/total)*100}%`;
      document.getElementById(labelId).textContent = `${done} / ${total}`;
    }

