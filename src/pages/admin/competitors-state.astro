    <div class="form-actions">
      <button class="btn-primary" id="save-comp-btn">Save</button>
      <button class="btn-secondary" id="cancel-comp-btn">Cancel</button>
    </div>
  </div>
</div>

<!-- Add Activity Modal -->
<div id="activity-modal" class="modal-overlay" style="display:none">
