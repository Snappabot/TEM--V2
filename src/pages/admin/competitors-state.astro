    .comp-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 0.75rem; border-top: 1px solid #1e1e1e; }

    /* Inline editing */
    .inline-input { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 4px; color: #e5e5e5; font-size: 0.82rem; padding: 0.25rem 0.5rem; outline: none; width: 100%; font-family: inherit; }
    .inline-input:focus { border-color: #8b7355; }

    /* Activity feed */
