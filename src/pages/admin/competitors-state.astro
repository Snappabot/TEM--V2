  async function sbGet(table: string, q = '') { const r = await fetch(`${SB_URL}/rest/v1/${table}?${q}`, { headers: sbH() }); if (!r.ok) throw new Error(await r.text()); return r.json(); }
  async function sbInsert(table: string, data: any) { const r = await fetch(`${SB_URL}/rest/v1/${table}`, { method: 'POST', headers: sbH(), body: JSON.stringify(data) }); if (!r.ok) throw new Error(await r.text()); return r.json(); }
  async function sbPatch(table: string, id: string, data: any) { const r = await fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'PATCH', headers: sbH(), body: JSON.stringify(data) }); if (!r.ok) throw new Error(await r.text()); return r.json(); }

  function tierBadge(t: string) {
    const m: any = { budget: 'badge-budget', mid: 'badge-mid', premium: 'badge-premium', luxury: 'badge-luxury' };
    return `<span class="badge ${m[t]||'badge-mid'}">${t||'mid'}</span>`;
  }

  let allComps: any[] = [];
  let activeState = 'VIC';

  async function loadComps() {
    const grid = document.getElementById('comp-grid')!;
    try {
      allComps = await sbGet('state_competitors', 'order=state.asc,rank.asc');
      populateCompSelect();
      renderComps();
    } catch(e) {
      grid.innerHTML = '<div class="empty">Error loading. Check state_competitors table exists.</div>';
    }
  }

  function populateCompSelect() {
    const sel = document.getElementById('act-comp') as HTMLSelectElement;
    sel.innerHTML = allComps.map(c => `<option value="${c.id}">${c.business_name} (${c.state})</option>`).join('');
  }

  function renderComps() {
    const grid = document.getElementById('comp-grid')!;
    const comps = allComps.filter(c => c.state === activeState).sort((a,b) => (a.rank||99)-(b.rank||99));
    if (!comps.length) { grid.innerHTML = `<div class="empty">No competitors recorded for ${activeState} yet. Add one or seed default data.</div>`; return; }

    grid.innerHTML = comps.map(c => {
      const hasNatural = (c.speciality||[]).some((s: string) => ['lime','hemp','clay'].includes(s));
      return `<div class="comp-card ${c.monitored ? 'monitored' : ''}" id="comp-card-${c.id}">
        <div class="comp-rank">${c.rank||'?'}</div>
        <div class="comp-name">${c.business_name}</div>
        <div class="comp-sub">${c.state} ${c.pricing_tier ? `· ${c.pricing_tier}` : ''}</div>
        <div class="comp-stats">
          ${c.instagram_followers ? `<span>IG: ${c.instagram_followers.toLocaleString()}</span>` : ''}
          ${c.google_rating ? `<span>⭐ ${c.google_rating} (${c.google_reviews||0})</span>` : ''}
        </div>
        <div class="comp-tags">
          ${tierBadge(c.pricing_tier)}
          ${c.monitored ? '<span class="badge badge-monitored">Watching</span>' : ''}
          ${hasNatural ? '<span class="badge badge-warn">Natural overlaps TEM</span>' : ''}
          ${(c.speciality||[]).map((s: string)=>`<span class="badge badge-spec">${s.replace(/_/g,' ')}</span>`).join('')}
        </div>
        ${(c.products_used||[]).length ? `<div class="comp-products"><strong>Products:</strong> ${c.products_used.join(', ')}</div>` : ''}
        ${c.notes ? `<div style="font-size:0.78rem;color:#888;margin-bottom:0.75rem">${c.notes}</div>` : ''}
        <div class="comp-actions">
          ${c.instagram_handle ? `<a href="https://instagram.com/${c.instagram_handle.replace('@','')}" target="_blank" class="btn-sm">Instagram</a>` : ''}
          ${c.website ? `<a href="${c.website}" target="_blank" class="btn-sm">Website</a>` : ''}
          <button class="btn-sm ${c.monitored ? '' : 'btn-monitor'}" onclick="toggleMonitor('${c.id}', ${c.monitored})">${c.monitored ? 'Unwatch' : 'Watch'}</button>
          <button class="btn-sm" onclick="openEditComp('${c.id}')">Edit</button>
          <button class="btn-sm" onclick="openActivityForComp('${c.id}')">+ Activity</button>
        </div>
      </div>`;
    }).join('');
  }

  (window as any).toggleMonitor = async function(id: string, current: boolean) {
    await sbPatch('state_competitors', id, { monitored: !current });
    const c = allComps.find(x => x.id === id);
    if (c) c.monitored = !current;
    renderComps();
  };

  (window as any).openEditComp = function(id: string) {
    const c = allComps.find(x => x.id === id);
    if (!c) return;
    (document.getElementById('cm-name') as HTMLInputElement).value = c.business_name;
    (document.getElementById('cm-state') as HTMLSelectElement).value = c.state;
    (document.getElementById('cm-rank') as HTMLInputElement).value = c.rank || '';
    (document.getElementById('cm-tier') as HTMLSelectElement).value = c.pricing_tier || 'mid';
    (document.getElementById('cm-insta') as HTMLInputElement).value = c.instagram_handle || '';
    (document.getElementById('cm-website') as HTMLInputElement).value = c.website || '';
    (document.getElementById('cm-followers') as HTMLInputElement).value = c.instagram_followers || '';
    (document.getElementById('cm-rating') as HTMLInputElement).value = c.google_rating || '';
    (document.getElementById('cm-reviews') as HTMLInputElement).value = c.google_reviews || '';
    (document.getElementById('cm-spec') as HTMLInputElement).value = (c.speciality||[]).join(', ');
    (document.getElementById('cm-products') as HTMLInputElement).value = (c.products_used||[]).join(', ');
    (document.getElementById('cm-notes') as HTMLTextAreaElement).value = c.notes || '';
    const modal = document.getElementById('comp-modal')!;
    modal.style.display = 'flex';
    const saveBtn = document.getElementById('save-comp-btn')!;
    saveBtn.dataset.editId = id;
  };

  (window as any).openActivityForComp = function(id: string) {
    document.getElementById('activity-modal')!.style.display = 'flex';
    (document.getElementById('act-comp') as HTMLSelectElement).value = id;
    const today = new Date().toISOString().split('T')[0];
    (document.getElementById('act-date') as HTMLInputElement).value = today;
  };

  async function loadActivity() {
    const feed = document.getElementById('activity-feed')!;
    try {
      const activities = await sbGet('competitor_activity', 'order=spotted_date.desc&limit=50');
      if (!activities.length) { feed.innerHTML = '<div class="empty">No activity logged yet.</div>'; return; }
      const compMap: any = {};
      allComps.forEach(c => compMap[c.id] = c);
      const typeLabels: any = { new_project:'New Project', new_product:'New Product', price_change:'Price Change', collaboration:'Collaboration', award:'Award', social_campaign:'Social Campaign' };
      feed.innerHTML = activities.map((a: any) => {
        const c = compMap[a.competitor_id];
        return `<div class="activity-item">
          <div class="activity-header">
            <div>
              <span class="activity-type">${typeLabels[a.activity_type]||a.activity_type}</span>
              <span style="color:#888;font-size:0.8rem;margin-left:0.5rem">${c ? `— ${c.business_name} (${c.state})` : ''}</span>
            </div>
            <span class="activity-date">${a.spotted_date||''}</span>
          </div>
          <div class="activity-desc">${a.description||''}</div>
          ${a.notes ? `<div class="activity-sub">TEM response: ${a.notes}</div>` : ''}
          ${a.source_url ? `<div style="margin-top:0.25rem"><a href="${a.source_url}" target="_blank" style="font-size:0.75rem">Source →</a></div>` : ''}
        </div>`;
      }).join('');
    } catch(e) {
      feed.innerHTML = '<div class="empty">Error loading activity.</div>';
    }
  }

  // State tabs
  document.querySelectorAll('.state-tab').forEach(btn => {
    btn.addEventListener('click', (e) => {
      activeState = (e.currentTarget as HTMLElement).dataset.state!;
      document.querySelectorAll('.state-tab').forEach(b => b.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      renderComps();
    });
  });

  // Seed
  document.getElementById('seed-competitors-btn')!.addEventListener('click', async () => {
    if (!confirm('Seed default competitors (VIC/NSW/QLD)? This adds them to the database.')) return;
    for (const c of SEED_COMPETITORS) await sbInsert('state_competitors', c);
    loadComps();
  });

  // Add competitor modal
  document.getElementById('add-comp-btn')!.addEventListener('click', () => {
    const saveBtn = document.getElementById('save-comp-btn')!;
    delete saveBtn.dataset.editId;
    document.getElementById('comp-modal')!.style.display = 'flex';
  });
  document.getElementById('cancel-comp-btn')!.addEventListener('click', () => { document.getElementById('comp-modal')!.style.display = 'none'; });
  document.getElementById('save-comp-btn')!.addEventListener('click', async () => {
    const name = (document.getElementById('cm-name') as HTMLInputElement).value.trim();
    if (!name) { alert('Business name required'); return; }
    const spec = (document.getElementById('cm-spec') as HTMLInputElement).value.split(',').map(s=>s.trim()).filter(Boolean);
    const products = (document.getElementById('cm-products') as HTMLInputElement).value.split(',').map(s=>s.trim()).filter(Boolean);
    const data: any = {
      business_name: name,
      state: (document.getElementById('cm-state') as HTMLSelectElement).value,
      rank: parseInt((document.getElementById('cm-rank') as HTMLInputElement).value) || null,
      pricing_tier: (document.getElementById('cm-tier') as HTMLSelectElement).value,
      instagram_handle: (document.getElementById('cm-insta') as HTMLInputElement).value || null,
      website: (document.getElementById('cm-website') as HTMLInputElement).value || null,
      instagram_followers: parseInt((document.getElementById('cm-followers') as HTMLInputElement).value) || null,
      google_rating: parseFloat((document.getElementById('cm-rating') as HTMLInputElement).value) || null,
      google_reviews: parseInt((document.getElementById('cm-reviews') as HTMLInputElement).value) || null,
      speciality: spec,
      products_used: products,
      notes: (document.getElementById('cm-notes') as HTMLTextAreaElement).value || null,
      last_updated: new Date().toISOString().split('T')[0],
    };
    const editId = (document.getElementById('save-comp-btn') as HTMLElement).dataset.editId;
    if (editId) {
      await sbPatch('state_competitors', editId, data);
    } else {
      await sbInsert('state_competitors', data);
    }
    document.getElementById('comp-modal')!.style.display = 'none';
    await loadComps();
  });

  // Activity modal
  document.getElementById('add-activity-btn')!.addEventListener('click', () => {
    const today = new Date().toISOString().split('T')[0];
    (document.getElementById('act-date') as HTMLInputElement).value = today;
    document.getElementById('activity-modal')!.style.display = 'flex';
  });
  document.getElementById('cancel-activity-btn')!.addEventListener('click', () => { document.getElementById('activity-modal')!.style.display = 'none'; });
  document.getElementById('save-activity-btn')!.addEventListener('click', async () => {
    const desc = (document.getElementById('act-desc') as HTMLTextAreaElement).value.trim();
    if (!desc) { alert('Description required'); return; }
    await sbInsert('competitor_activity', {
      competitor_id: (document.getElementById('act-comp') as HTMLSelectElement).value || null,
      activity_type: (document.getElementById('act-type') as HTMLSelectElement).value,
      description: desc,
      spotted_date: (document.getElementById('act-date') as HTMLInputElement).value || null,
      source_url: (document.getElementById('act-url') as HTMLInputElement).value || null,
      notes: (document.getElementById('act-notes') as HTMLTextAreaElement).value || null,
    });
    document.getElementById('activity-modal')!.style.display = 'none';
    loadActivity();
  });

  // Main tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const tab = (e.currentTarget as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      document.getElementById(`tab-${tab}`)!.classList.add('active');
      if (tab === 'activity') loadActivity();
    });
  });

  // Auth
  const gate = document.getElementById('gate')!;
  const app = document.getElementById('app')!;
  const pwInput = document.getElementById('pw-input') as HTMLInputElement;
  function tryLogin(pw: string) {
    if (pw === ADMIN_PW) {
      sessionStorage.setItem('tem-admin-password', pw);
      gate.style.display = 'none';
      app.style.display = 'block';
      loadComps();
    } else {
      const e = document.getElementById('pw-error')!;
      e.textContent = 'Invalid password';
      e.style.display = 'block';
    }
  }
  if (sessionStorage.getItem('tem-admin-password') === ADMIN_PW) { gate.style.display = 'none'; app.style.display = 'block'; loadComps(); }
  document.getElementById('pw-btn')!.addEventListener('click', () => tryLogin(pwInput.value));
  pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(pwInput.value); });
  document.getElementById('logout-btn')!.addEventListener('click', () => { sessionStorage.removeItem('tem-admin-password'); gate.style.display = 'flex'; app.style.display = 'none'; });
</script>
</body>
</html>
