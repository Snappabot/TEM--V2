      <div class="form-group"><label>Source URL</label><input type="url" id="act-url" /></div>
    </div>
    <div class="form-row single">
      <div class="form-group"><label>Description *</label><textarea id="act-desc" placeholder="What did you spot?"></textarea></div>
    </div>
    <div class="form-row single">
      <div class="form-group"><label>Notes / TEM Response</label><textarea id="act-notes" placeholder="What should TEM do in response?"></textarea></div>
    </div>
    <div class="form-actions">
      <button class="btn-primary" id="save-activity-btn">Save</button>
      <button class="btn-secondary" id="cancel-activity-btn">Cancel</button>
    </div>
  </div>
</div>

