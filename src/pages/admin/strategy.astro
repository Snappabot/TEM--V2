                <input type="checkbox" id="perf-webp" />
                <label for="perf-webp">Images served in WebP/AVIF format</label>
                <span class="checklist-tooltip" data-tip="Astro's &lt;Image /&gt; component handles this automatically. Verify with DevTools → Network → filter by Img — file types should show webp or avif.">i</span>
              </div>
              <div class="checklist-item" data-id="perf-lazy">
                <input type="checkbox" id="perf-lazy" />
                <label for="perf-lazy">Lazy loading on below-fold images ✓</label>
                <span class="checklist-tooltip" data-tip="Already implemented. Astro's Image component adds loading='lazy' by default. Above-fold hero images should have loading='eager' or fetchpriority='high'.">i</span>
              </div>
              <div class="checklist-item" data-id="perf-scripts">
                <input type="checkbox" id="perf-scripts" />
                <label for="perf-scripts">No render-blocking scripts</label>
                <span class="checklist-tooltip" data-tip="Check PageSpeed Insights → 'Eliminate render-blocking resources'. Move scripts to end of body or add defer/async attributes. Third-party scripts (analytics, chat) are common culprits.">i</span>
              </div>
              <div class="checklist-item" data-id="perf-fonts">
                <input type="checkbox" id="perf-fonts" />
                <label for="perf-fonts">Font loading optimised (font-display: swap)</label>
                <span class="checklist-tooltip" data-tip="Add font-display: swap to @font-face declarations. Preload critical fonts with &lt;link rel='preload' as='font'&gt;. Consider using system fonts for body text.">i</span>
              </div>
            </div>

            <!-- Mobile & UX -->
            <div class="checklist-category">
              <div class="checklist-category-title">Mobile &amp; UX</div>
              <div class="checklist-item" data-id="mobile-responsive">
                <input type="checkbox" id="mobile-responsive" />
                <label for="mobile-responsive">Fully responsive on all screen sizes</label>
                <span class="checklist-tooltip" data-tip="Test in Chrome DevTools Device Mode at 320px, 375px, 414px, 768px. Use GSC → Mobile Usability report to catch issues Google has already flagged.">i</span>
              </div>
              <div class="checklist-item" data-id="mobile-nohscroll">
                <input type="checkbox" id="mobile-nohscroll" />
                <label for="mobile-nohscroll">No horizontal scroll on mobile</label>
                <span class="checklist-tooltip" data-tip="Check overflow-x on body and all containers. Common culprits: wide tables, fixed-width elements, negative margins. Add overflow-x: hidden to body as a last resort.">i</span>
              </div>
              <div class="checklist-item" data-id="mobile-taptargets">
                <input type="checkbox" id="mobile-taptargets" />
                <label for="mobile-taptargets">Tap targets &ge; 48px</label>
                <span class="checklist-tooltip" data-tip="Buttons and links should be at least 48×48px to be easily tappable. PageSpeed Insights flags tap targets that are too small or too close together.">i</span>
              </div>
              <div class="checklist-item" data-id="mobile-cta">
                <input type="checkbox" id="mobile-cta" />
                <label for="mobile-cta">Contact CTA visible above fold on mobile</label>
                <span class="checklist-tooltip" data-tip="Users should see a phone number or 'Get a Quote' button without scrolling on a 375px screen. Test on real device or in Chrome DevTools at 375px × 812px.">i</span>
              </div>
            </div>

            <!-- GEO / AI Visibility -->
            <div class="checklist-category">
              <div class="checklist-category-title">GEO / AI Visibility</div>
              <div class="checklist-item" data-id="geo-llmstxt">
                <input type="checkbox" id="geo-llmstxt" />
                <label for="geo-llmstxt">llms.txt present ✓</label>
                <span class="checklist-tooltip" data-tip="Already deployed. Verify at yourdomain.com/llms.txt. Ensure it accurately describes TEM's products, location, and key differentiators for AI consumption.">i</span>
              </div>
              <div class="checklist-item" data-id="geo-brand">
                <input type="checkbox" id="geo-brand" />
                <label for="geo-brand">Clear brand entity definition in homepage copy</label>
                <span class="checklist-tooltip" data-tip="The homepage should clearly state: who TEM is, what they do (decorative plaster, hemp render, lime plaster), where they operate (Melbourne), and what makes them unique (carbon sequestration, natural materials).">i</span>
              </div>
              <div class="checklist-item" data-id="geo-faq">
                <input type="checkbox" id="geo-faq" />
                <label for="geo-faq">FAQ content present for key AI answer extraction</label>
                <span class="checklist-tooltip" data-tip="Add FAQ sections or pages covering common questions: 'What is venetian plaster?', 'Is hemp render carbon negative?', 'How long does decorative plaster last?'. These are prime AI snippet candidates.">i</span>
              </div>
              <div class="checklist-item" data-id="geo-nap">
                <input type="checkbox" id="geo-nap" />
                <label for="geo-nap">Consistent NAP (Name/Address/Phone) across all pages</label>
                <span class="checklist-tooltip" data-tip="Business name, address, and phone number must be identical everywhere online: website footer, GSC, Google Business Profile, social profiles, directory listings.">i</span>
              </div>
              <div class="checklist-item" data-id="geo-gbp">
                <input type="checkbox" id="geo-gbp" />
                <label for="geo-gbp">Google Business Profile claimed and optimised</label>
                <span class="checklist-tooltip" data-tip="Claim at business.google.com. Complete all fields: description, services, photos (10+ high quality), opening hours, service areas. Respond to all reviews. Post weekly updates.">i</span>
              </div>
            </div>

          </div><!-- /.collapsible-body -->
        </div><!-- /.seo-checklist-panel -->

      </div><!-- /.dash-body -->
    </div><!-- /#dashboard-section -->

    <script>
      const ADMIN_PASSWORD = 'TEM-admin-2026!';
      let pw: string | null = null;

      // ── Auth ──────────────────────────────────────────────────────
      const loginSection = document.getElementById('login-section')!;
      const dashSection = document.getElementById('dashboard-section')!;
      const loginError = document.getElementById('login-error')!;
      const passwordInput = document.getElementById('admin-password') as HTMLInputElement;

      const stored = sessionStorage.getItem('tem-admin-pw');
      if (stored === ADMIN_PASSWORD) { pw = stored; showDash(); }

      document.getElementById('login-btn')!.addEventListener('click', () => {
        const val = passwordInput.value;
        if (val === ADMIN_PASSWORD) {
          pw = val;
          sessionStorage.setItem('tem-admin-pw', val);
          loginError.style.display = 'none';
          showDash();
        } else {
          loginError.textContent = 'Invalid password';
          loginError.style.display = 'block';
        }
      });

      passwordInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') document.getElementById('login-btn')!.click();
      });

      document.getElementById('logout-btn')!.addEventListener('click', () => {
        pw = null;
        sessionStorage.removeItem('tem-admin-pw');
        loginSection.style.display = 'flex';
        dashSection.style.display = 'none';
      });

      function showDash() {
        loginSection.style.display = 'none';
        dashSection.style.display = 'block';
      }

      // ── Campaign card expand/collapse ─────────────────────────────
      document.querySelectorAll<HTMLElement>('.campaign-card').forEach(card => {
        const header = card.querySelector<HTMLElement>('.campaign-card-header');
        if (header) {
          header.addEventListener('click', () => {
            card.classList.toggle('open');
          });
        }
      });

      // ── UTM Builder ───────────────────────────────────────────────
      function buildUTM() {
        const base = (document.getElementById('utm-url') as HTMLInputElement).value.trim();
        const campaign = (document.getElementById('utm-campaign-select') as HTMLSelectElement).value;
        const source = (document.getElementById('utm-source') as HTMLSelectElement).value;
        const medium = (document.getElementById('utm-medium') as HTMLSelectElement).value;
        const content = (document.getElementById('utm-content') as HTMLInputElement).value.trim();

        if (!base || !campaign || !source || !medium) {
          alert('Base URL, campaign, source, and medium are all required.');
          return;
        }

        let url: URL;
        try {
          url = new URL(base);
        } catch {
          alert('Please enter a valid URL including https://');
          return;
        }

        url.searchParams.set('utm_source', source);
        url.searchParams.set('utm_medium', medium);
        url.searchParams.set('utm_campaign', campaign);
        if (content) url.searchParams.set('utm_content', content);

        document.getElementById('utm-result')!.textContent = url.toString();
        document.getElementById('utm-output')!.style.display = 'block';
      }

      document.getElementById('utm-build-btn')!.addEventListener('click', buildUTM);

      document.getElementById('utm-clear-btn')!.addEventListener('click', () => {
        (document.getElementById('utm-url') as HTMLInputElement).value = 'https://troweledearthmelbourne.com.au/';
        (document.getElementById('utm-campaign-select') as HTMLSelectElement).value = '';
        (document.getElementById('utm-source') as HTMLSelectElement).value = '';
        (document.getElementById('utm-medium') as HTMLSelectElement).value = '';
        (document.getElementById('utm-content') as HTMLInputElement).value = '';
        document.getElementById('utm-output')!.style.display = 'none';
      });

      document.getElementById('utm-copy-btn')!.addEventListener('click', () => {
        const text = document.getElementById('utm-result')!.textContent || '';
        navigator.clipboard.writeText(text);
        const btn = document.getElementById('utm-copy-btn')!;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy URL', 2000);
      });

      // ── Technical SEO Checklist ───────────────────────────────────
      const CHECKLIST_KEY = 'tem-seo-checklist';
      const PRE_CHECKED = ['crawl-robots', 'schema-localbusiness', 'perf-lazy', 'geo-llmstxt'];
      const ALL_IDS = [
        'cwv-lcp','cwv-inp','cwv-cls','cwv-mobile-ps','cwv-desktop-ps',
        'crawl-robots','crawl-sitemap','crawl-errors','crawl-indexed','crawl-noindex',
        'schema-localbusiness','schema-service','schema-faq','schema-breadcrumb','schema-validated',
        'onpage-titles','onpage-meta','onpage-h1','onpage-alt','onpage-internal',
        'perf-webp','perf-lazy','perf-scripts','perf-fonts',
        'mobile-responsive','mobile-nohscroll','mobile-taptargets','mobile-cta',
        'geo-llmstxt','geo-brand','geo-faq','geo-nap','geo-gbp'
      ];

      // Load saved state or initialise with pre-checked defaults
      let savedState: Record<string, boolean> = {};
      try {
        const stored = localStorage.getItem(CHECKLIST_KEY);
        if (stored) {
          savedState = JSON.parse(stored);
        } else {
          PRE_CHECKED.forEach(id => { savedState[id] = true; });
        }
      } catch { /* ignore */ }

      function persistState() {
        try { localStorage.setItem(CHECKLIST_KEY, JSON.stringify(savedState)); } catch { /* ignore */ }
      }

      function updateProgress() {
        const checked = ALL_IDS.filter(id => savedState[id]).length;
        const total = ALL_IDS.length;
        const pct = Math.round((checked / total) * 100);
        const bar = document.getElementById('checklist-progress-bar') as HTMLElement;
        const text = document.getElementById('checklist-progress-text') as HTMLElement;
        const label = document.getElementById('checklist-pct-label') as HTMLElement;
        if (bar) bar.style.width = pct + '%';
        if (text) text.textContent = `${checked} of ${total} items complete`;
        if (label) label.textContent = pct + '% complete';
      }

      // Initialise checkboxes
      ALL_IDS.forEach(id => {
        const cb = document.getElementById(id) as HTMLInputElement;
        const item = cb?.closest('.checklist-item') as HTMLElement;
        if (!cb) return;
        cb.checked = !!savedState[id];
        if (cb.checked) item?.classList.add('checked');

        cb.addEventListener('change', () => {
          savedState[id] = cb.checked;
          if (cb.checked) item?.classList.add('checked');
          else item?.classList.remove('checked');
          persistState();
          updateProgress();
        });
      });

      updateProgress();

      // Toggle panel open/close
      const seoPanel = document.getElementById('seo-checklist-panel')!;
      const seoChevron = document.getElementById('seo-checklist-chevron')!;
      document.getElementById('seo-checklist-toggle')!.addEventListener('click', () => {
        const isOpen = seoPanel.classList.toggle('open');
        seoChevron.style.transform = isOpen ? 'rotate(180deg)' : '';
      });

      // Export
      document.getElementById('checklist-export-btn')!.addEventListener('click', () => {
        if (!seoPanel.classList.contains('open')) seoPanel.classList.add('open');
        window.print();
      });

      // Reset
      document.getElementById('checklist-reset-btn')!.addEventListener('click', () => {
        if (!confirm('Reset all checklist items to default? Pre-checked items will be restored.')) return;
        savedState = {};
        PRE_CHECKED.forEach(id => { savedState[id] = true; });
        persistState();
        ALL_IDS.forEach(id => {
          const cb = document.getElementById(id) as HTMLInputElement;
          const item = cb?.closest('.checklist-item') as HTMLElement;
          if (!cb) return;
          cb.checked = !!savedState[id];
          if (cb.checked) item?.classList.add('checked');
          else item?.classList.remove('checked');
        });
        updateProgress();
      });
    </script>
  </body>
</html>
