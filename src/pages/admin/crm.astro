    { name: 'Eckersley Garden Architecture', company: 'EGA', role: 'architect', state: 'VIC', instagram_handle: '@ega_landscape', priority: 'cold', status: 'identified' },
    { name: 'Joost Bakker', company: 'Independent', role: 'other', state: 'VIC', instagram_handle: '@joostbakker', priority: 'hot', status: 'identified', notes: 'Sustainability/hemp angle — strong alignment', finish_affinity: ['hemp','clay'] },
    { name: 'Amber Road', company: 'Amber Road', role: 'interior_designer', state: 'NSW', instagram_handle: '@amber_road', priority: 'warm', status: 'identified' },
  ];

  function sbH() {
    return { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' };
  }
  async function sbGet(table: string, q = '') {
    const r = await fetch(`${SB_URL}/rest/v1/${table}?${q}`, { headers: sbH() });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }
  async function sbInsert(table: string, data: any) {
    const r = await fetch(`${SB_URL}/rest/v1/${table}`, { method: 'POST', headers: sbH(), body: JSON.stringify(data) });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }
  async function sbPatch(table: string, id: string, data: any) {
    const r = await fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'PATCH', headers: sbH(), body: JSON.stringify(data) });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }

  function priorityBadge(p: string) {
    const m: any = { hot: 'badge-hot', warm: 'badge-warm', cold: 'badge-cold' };
    return `<span class="badge ${m[p]||'badge-cold'}">${p||'cold'}</span>`;
  }
  function statusBadge(s: string) {
    const m: any = { identified:'badge-identified', emailed:'badge-emailed', responded:'badge-responded', meeting_booked:'badge-meeting_booked', client:'badge-client', passed:'badge-passed' };
    return `<span class="badge ${m[s]||'badge-identified'}">${(s||'identified').replace('_',' ')}</span>`;
  }

  let allContacts: any[] = [];
  let pipeFilter = '';
  let emailHistory: any[] = [];

  async function loadContacts() {
    const list = document.getElementById('contact-list')!;
    try {
      allContacts = await sbGet('contacts', 'order=created_at.asc');
      updatePipeline();
      checkFollowUps();
      renderContacts();
      populateEmailContactSelect();
    } catch(e) {
      list.innerHTML = '<div class="empty">Error loading. Check Supabase table exists.</div>';
    }
  }

  function updatePipeline() {
    const counts: any = { '': allContacts.length };
    ['identified','emailed','responded','meeting_booked','client'].forEach(s => {
      counts[s] = allContacts.filter(c => c.status === s).length;
    });
    document.getElementById('pipe-all')!.textContent = counts[''];
    ['identified','emailed','responded','meeting_booked','client'].forEach(s => {
      document.getElementById(`pipe-${s}`)!.textContent = counts[s];
    });
  }

  function checkFollowUps() {
    const today = new Date().toISOString().split('T')[0];
    const due = allContacts.filter(c => c.last_contacted && c.status === 'emailed');
    if (due.length) {
      document.getElementById('followup-banner')!.style.display = 'block';
      document.getElementById('followup-banner')!.textContent = `${due.length} contact(s) emailed — check follow-up dates in Email Campaigns tab.`;
    }
  }

  function renderContacts() {
    const list = document.getElementById('contact-list')!;
    const stateF = (document.getElementById('filter-state') as HTMLSelectElement).value;
    const roleF = (document.getElementById('filter-role') as HTMLSelectElement).value;
    const priF = (document.getElementById('filter-priority') as HTMLSelectElement).value;

    let cs = allContacts;
    if (pipeFilter) cs = cs.filter(c => c.status === pipeFilter);
    if (stateF) cs = cs.filter(c => c.state === stateF);
    if (roleF) cs = cs.filter(c => c.role === roleF);
    if (priF) cs = cs.filter(c => c.priority === priF);

    if (!cs.length) { list.innerHTML = '<div class="empty">No contacts found.</div>'; return; }

    list.innerHTML = cs.map(c => `
      <div class="contact-row" id="row-${c.id}">
        <div class="contact-row-main" onclick="toggleDetail('${c.id}')">
          <span class="contact-name">${c.name}</span>
          <span class="contact-company">${c.company||''} ${c.state ? `· ${c.state}` : ''}</span>
          <div class="contact-row-meta">
            ${priorityBadge(c.priority)} ${statusBadge(c.status)}
            ${c.instagram_handle ? `<span style="font-size:0.75rem;color:#8b7355">${c.instagram_handle}</span>` : ''}
          </div>
        </div>
        <div class="contact-detail" id="detail-${c.id}">
          <div class="detail-grid">
            <div class="detail-item"><label>Role</label><span>${c.role?.replace(/_/g,' ')||'—'}</span></div>
            <div class="detail-item"><label>Email</label><span>${c.email||'—'}</span></div>
            <div class="detail-item"><label>Website</label><span>${c.website ? `<a href="${c.website}" target="_blank">${c.website}</a>` : '—'}</span></div>
            <div class="detail-item"><label>Source</label><span>${c.source||'—'}</span></div>
            <div class="detail-item"><label>Last Contacted</label><span>${c.last_contacted||'—'}</span></div>
            <div class="detail-item"><label>TEM Used</label><span>${c.tem_used ? '✓ Yes' : 'No'}</span></div>
          </div>
          ${c.notes ? `<div style="font-size:0.82rem;color:#888;margin-bottom:0.75rem;padding:0.625rem;background:#1a1a1a;border-radius:6px">${c.notes}</div>` : ''}
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
            <select class="filter-select" onchange="updateStatus('${c.id}', this.value)" style="font-size:0.75rem;padding:0.25rem 0.5rem">
              ${['identified','emailed','responded','meeting_booked','client','passed'].map(s=>`<option value="${s}" ${c.status===s?'selected':''}>${s.replace('_',' ')}</option>`).join('')}
            </select>
            <button class="btn-sm" onclick="openLogEmail('${c.id}')">Log Email</button>
            <div id="emails-${c.id}" style="width:100%;margin-top:0.5rem"></div>
          </div>
        </div>
      </div>
    `).join('');
  }

  (window as any).toggleDetail = async function(id: string) {
    const detail = document.getElementById(`detail-${id}`)!;
    const row = document.getElementById(`row-${id}`)!;
    const isOpen = detail.classList.contains('show');
    document.querySelectorAll('.contact-detail').forEach(d => d.classList.remove('show'));
    document.querySelectorAll('.contact-row').forEach(r => r.classList.remove('expanded'));
    if (!isOpen) {
      detail.classList.add('show');
      row.classList.add('expanded');
      await loadContactEmails(id);
    }
  };

  async function loadContactEmails(contactId: string) {
    const container = document.getElementById(`emails-${contactId}`)!;
    try {
      const emails = await sbGet('outreach_emails', `contact_id=eq.${contactId}&order=sent_date.desc`);
      if (!emails.length) { container.innerHTML = '<div style="font-size:0.78rem;color:#555">No emails logged yet.</div>'; return; }
      container.innerHTML = `<div class="email-history"><h4>Email History</h4>${emails.map((e: any) => `
        <div class="email-item">
          <div class="email-item-header">
            <span>${e.email_subject||'(no subject)'}</span>
            <span style="color:#555">${e.sent_date||''}</span>
          </div>
          <div style="color:#888;font-size:0.75rem">${e.campaign_name||''} · Opened: ${e.opened?'Yes':'No'} · Replied: ${e.replied?'Yes':'No'}${e.follow_up_date ? ` · Follow-up: ${e.follow_up_date}` : ''}</div>
          ${e.notes ? `<div style="margin-top:0.25rem;color:#aaa">${e.notes}</div>` : ''}
        </div>`).join('')}</div>`;
    } catch(e) { container.innerHTML = ''; }
  }

  (window as any).updateStatus = async function(id: string, status: string) {
    await sbPatch('contacts', id, { status });
    const c = allContacts.find(c => c.id === id);
    if (c) c.status = status;
    updatePipeline();
    renderContacts();
  };

  function openLogEmail(contactId: string = '') {
    document.getElementById('email-modal')!.style.display = 'flex';
    if (contactId) (document.getElementById('email-contact-id') as HTMLSelectElement).value = contactId;
    const today = new Date().toISOString().split('T')[0];
    (document.getElementById('email-sent-date') as HTMLInputElement).value = today;
  }
  (window as any).openLogEmail = openLogEmail;

  function populateEmailContactSelect() {
    const sel = document.getElementById('email-contact-id') as HTMLSelectElement;
    sel.innerHTML = allContacts.map(c => `<option value="${c.id}">${c.name}${c.company ? ` (${c.company})` : ''}</option>`).join('');
  }

  async function loadOutreach() {
    const list = document.getElementById('outreach-list')!;
    const today = new Date().toISOString().split('T')[0];
    try {
      const emails = await sbGet('outreach_emails', 'order=sent_date.desc');
      if (!emails.length) { list.innerHTML = '<div class="empty">No outreach logged yet.</div>'; return; }
      const contactMap: any = {};
      allContacts.forEach(c => contactMap[c.id] = c);
      list.innerHTML = `<div class="contact-list">${emails.map((e: any) => {
        const c = contactMap[e.contact_id];
        const overdue = e.follow_up_date && e.follow_up_date <= today && !e.replied;
        return `<div class="contact-row">
          <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <span style="font-weight:500">${c?.name||'Unknown'}</span>
            <span style="color:#888;font-size:0.85rem">${e.email_subject||'(no subject)'}</span>
            <span style="color:#555;font-size:0.8rem">${e.sent_date||''}</span>
            ${overdue ? '<span class="badge badge-follow-up">Follow-up Due</span>' : ''}
            <span class="badge ${e.replied ? 'badge-responded' : e.opened ? 'badge-emailed' : 'badge-identified'}">${e.replied ? 'Replied' : e.opened ? 'Opened' : 'Sent'}</span>
          </div>
          ${e.notes ? `<div style="font-size:0.8rem;color:#888;margin-top:0.5rem">${e.notes}</div>` : ''}
        </div>`;
      }).join('')}</div>`;
    } catch(e) {
      list.innerHTML = '<div class="empty">Error loading outreach.</div>';
    }
  }

  async function loadClients() {
    const grid = document.getElementById('clients-grid')!;
    try {
      const clients = await sbGet('tem_clients', 'order=created_at.desc');
      if (!clients.length) { grid.innerHTML = '<div class="empty">No TEM clients logged yet.</div>'; return; }
      grid.innerHTML = clients.map((c: any) => `
        <div class="portfolio-card">
          <h3>${c.name}</h3>
          <div class="sub">${c.company||''} ${c.role ? `· ${c.role}` : ''}</div>
          ${c.project_name ? `<div style="font-size:0.8rem;margin-bottom:0.5rem"><strong>Project:</strong> ${c.project_name}${c.project_location ? ` · ${c.project_location}` : ''}</div>` : ''}
          <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:0.5rem">
            ${(c.finishes_used||[]).map((f: string)=>`<span class="badge badge-finish">${f}</span>`).join('')}
          </div>
          ${c.instagram_handle ? `<a href="https://instagram.com/${c.instagram_handle.replace('@','')}" target="_blank" style="font-size:0.78rem">${c.instagram_handle}</a>` : ''}
          ${c.notes ? `<div style="font-size:0.78rem;color:#888;margin-top:0.5rem">${c.notes}</div>` : ''}
        </div>
      `).join('');
    } catch(e) {
      grid.innerHTML = '<div class="empty">Error loading clients.</div>';
    }
  }

  // Export CSV
  document.getElementById('export-csv-btn')!.addEventListener('click', () => {
    const headers = ['Name','Company','Role','State','Instagram','Email','Priority','Status','Notes'];
    const rows = allContacts.map(c => [c.name,c.company,c.role,c.state,c.instagram_handle,c.email,c.priority,c.status,c.notes].map(v => `"${(v||'').replace(/"/g,'""')}"`));
    const csv = [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
    const a = document.createElement('a');
    a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
    a.download = 'tem-contacts.csv';
    a.click();
  });

  // Seed contacts
  document.getElementById('seed-contacts-btn')!.addEventListener('click', async () => {
    if (!confirm('Seed 20 target contacts? This adds them to the database.')) return;
    for (const c of SEED_CONTACTS) await sbInsert('contacts', c);
    loadContacts();
  });

  // Pipeline filter
  document.querySelectorAll('.pipe-stage').forEach(btn => {
    btn.addEventListener('click', (e) => {
      pipeFilter = (e.currentTarget as HTMLElement).dataset.status!;
      document.querySelectorAll('.pipe-stage').forEach(b => b.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      renderContacts();
    });
  });

  ['filter-state','filter-role','filter-priority'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderContacts);
  });

  // Add contact modal
  document.getElementById('add-contact-btn')!.addEventListener('click', () => { document.getElementById('contact-modal')!.style.display = 'flex'; });
  document.getElementById('cancel-contact-btn')!.addEventListener('click', () => { document.getElementById('contact-modal')!.style.display = 'none'; });
  document.getElementById('save-contact-btn')!.addEventListener('click', async () => {
    const name = (document.getElementById('c-name') as HTMLInputElement).value.trim();
    if (!name) { alert('Name required'); return; }
    await sbInsert('contacts', {
      name,
      company: (document.getElementById('c-company') as HTMLInputElement).value||null,
      role: (document.getElementById('c-role') as HTMLSelectElement).value,
      state: (document.getElementById('c-state') as HTMLSelectElement).value,
      instagram_handle: (document.getElementById('c-insta') as HTMLInputElement).value||null,
      website: (document.getElementById('c-website') as HTMLInputElement).value||null,
      email: (document.getElementById('c-email') as HTMLInputElement).value||null,
      phone: (document.getElementById('c-phone') as HTMLInputElement).value||null,
      priority: (document.getElementById('c-priority') as HTMLSelectElement).value,
      status: (document.getElementById('c-status') as HTMLSelectElement).value,
      notes: (document.getElementById('c-notes') as HTMLTextAreaElement).value||null,
    });
    document.getElementById('contact-modal')!.style.display = 'none';
    loadContacts();
  });

  // Log email modal
  document.getElementById('log-email-btn')!.addEventListener('click', () => openLogEmail());
  document.getElementById('cancel-email-btn')!.addEventListener('click', () => { document.getElementById('email-modal')!.style.display = 'none'; });
  document.getElementById('save-email-btn')!.addEventListener('click', async () => {
    const contactId = (document.getElementById('email-contact-id') as HTMLSelectElement).value;
    await sbInsert('outreach_emails', {
      contact_id: contactId||null,
      campaign_name: (document.getElementById('email-campaign') as HTMLInputElement).value||null,
      email_subject: (document.getElementById('email-subject') as HTMLInputElement).value||null,
      sent_date: (document.getElementById('email-sent-date') as HTMLInputElement).value||null,
      opened: (document.getElementById('email-opened') as HTMLSelectElement).value === 'true',
      replied: (document.getElementById('email-replied') as HTMLSelectElement).value === 'true',
      follow_up_date: (document.getElementById('email-followup-date') as HTMLInputElement).value||null,
      notes: (document.getElementById('email-notes') as HTMLTextAreaElement).value||null,
    });
    if (contactId) await sbPatch('contacts', contactId, { status: 'emailed', last_contacted: new Date().toISOString().split('T')[0] });
    document.getElementById('email-modal')!.style.display = 'none';
    loadContacts();
  });

  // Add client modal
  document.getElementById('add-client-btn')!.addEventListener('click', () => { document.getElementById('client-modal')!.style.display = 'flex'; });
  document.getElementById('cancel-client-btn')!.addEventListener('click', () => { document.getElementById('client-modal')!.style.display = 'none'; });
  document.getElementById('save-client-btn')!.addEventListener('click', async () => {
    const name = (document.getElementById('cl-name') as HTMLInputElement).value.trim();
    if (!name) { alert('Name required'); return; }
    const finishes = (document.getElementById('cl-finishes') as HTMLInputElement).value.split(',').map(s=>s.trim()).filter(Boolean);
    await sbInsert('tem_clients', {
      name,
      company: (document.getElementById('cl-company') as HTMLInputElement).value||null,
      role: (document.getElementById('cl-role') as HTMLInputElement).value||null,
      project_name: (document.getElementById('cl-project') as HTMLInputElement).value||null,
      project_location: (document.getElementById('cl-location') as HTMLInputElement).value||null,
      project_date: (document.getElementById('cl-date') as HTMLInputElement).value||null,
      finishes_used: finishes,
      instagram_handle: (document.getElementById('cl-insta') as HTMLInputElement).value||null,
      notes: (document.getElementById('cl-notes') as HTMLTextAreaElement).value||null,
    });
    document.getElementById('client-modal')!.style.display = 'none';
    loadClients();
  });

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const tab = (e.currentTarget as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      document.getElementById(`tab-${tab}`)!.classList.add('active');
      if (tab === 'outreach') loadOutreach();
      if (tab === 'clients') loadClients();
    });
  });

  // Auth
  const gate = document.getElementById('gate')!;
  const app = document.getElementById('app')!;
  const pwInput = document.getElementById('pw-input') as HTMLInputElement;
  const pwBtn = document.getElementById('pw-btn')!;
  const pwError = document.getElementById('pw-error')!;

  function tryLogin(pw: string) {
    if (pw === ADMIN_PW) {
      sessionStorage.setItem('tem-admin-password', pw);
      gate.style.display = 'none';
      app.style.display = 'block';
      loadContacts();
    } else {
      pwError.textContent = 'Invalid password';
      pwError.style.display = 'block';
    }
  }

  if (sessionStorage.getItem('tem-admin-password') === ADMIN_PW) {
    gate.style.display = 'none';
    app.style.display = 'block';
    loadContacts();
  }

  pwBtn.addEventListener('click', () => tryLogin(pwInput.value));
  pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(pwInput.value); });
  document.getElementById('logout-btn')!.addEventListener('click', () => {
    sessionStorage.removeItem('tem-admin-password');
    gate.style.display = 'flex';
    app.style.display = 'none';
  });
</script>
</body>
</html>
