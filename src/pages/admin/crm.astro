    { name: 'SJB Architects', company: 'SJB', role: 'architect', state: 'VIC', instagram_handle: '@sjb_arch', priority: 'warm', status: 'identified' },
    { name: 'Technē Architecture', company: 'Technē Architecture', role: 'architect', state: 'VIC', instagram_handle: '@techne_architecture', priority: 'warm', status: 'identified' },
    { name: 'Nic Graham & Associates', company: 'Nic Graham & Associates', role: 'interior_designer', state: 'VIC', instagram_handle: '@nicgrahamassociates', priority: 'warm', status: 'identified' },
    { name: 'Six Degrees Architects', company: 'Six Degrees Architects', role: 'architect', state: 'VIC', instagram_handle: '@sixdegreesarchitects', priority: 'warm', status: 'identified' },
