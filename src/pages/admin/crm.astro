          <a href="/admin/future" class="nav-link">AI Future</a>
        </div>
      </div>
      <div class="nav-group">
        <span class="nav-label">Intelligence</span>
        <div class="nav-links">
          <a href="/admin/trends" class="nav-link">Trends</a>
          <a href="/admin/crm" class="nav-link active">CRM</a>
          <a href="/admin/portfolio" class="nav-link">Portfolio</a>
          <a href="/admin/mentions" class="nav-link">Mentions</a>
          <a href="/admin/competitors-state" class="nav-link">Competitors</a>
