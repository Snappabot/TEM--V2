      </div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Instagram Handle</label><input type="text" id="c-insta" placeholder="@handle" /></div>
      <div class="form-group"><label>Website</label><input type="url" id="c-website" placeholder="https://..." /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Email</label><input type="email" id="c-email" /></div>
      <div class="form-group"><label>Phone</label><input type="text" id="c-phone" /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Priority</label>
        <select id="c-priority"><option value="cold">Cold</option><option value="warm">Warm</option><option value="hot">Hot</option></select>
      </div>
      <div class="form-group"><label>Status</label>
        <select id="c-status"><option value="identified">Identified</option><option value="emailed">Emailed</option><option value="responded">Responded</option><option value="meeting_booked">Meeting Booked</option><option value="client">Client</option><option value="passed">Passed</option></select>
      </div>
    </div>
    <div class="form-row single">
      <div class="form-group"><label>Notes</label><textarea id="c-notes" placeholder="Style notes, finish affinity, context..."></textarea></div>
    </div>
    <div class="form-actions">
      <button class="btn-primary" id="save-contact-btn">Save Contact</button>
      <button class="btn-secondary" id="cancel-contact-btn">Cancel</button>
    </div>
  </div>
</div>

<!-- Add Client Modal -->
<div id="client-modal" class="modal-overlay" style="display:none">
  <div class="modal">
    <h3>Add TEM Client / Collaborator</h3>
    <div class="form-row">
      <div class="form-group"><label>Name *</label><input type="text" id="cl-name" /></div>
      <div class="form-group"><label>Company</label><input type="text" id="cl-company" /></div>
