    <div class="form-row">
      <div class="form-group"><label>Finishes Used (comma-sep)</label><input type="text" id="cl-finishes" placeholder="venetian, lime" /></div>
      <div class="form-group"><label>Instagram Handle</label><input type="text" id="cl-insta" /></div>
    </div>
    <div class="form-row single">
      <div class="form-group"><label>Notes</label><textarea id="cl-notes"></textarea></div>
    </div>
    <div class="form-actions">
      <button class="btn-primary" id="save-client-btn">Save</button>
      <button class="btn-secondary" id="cancel-client-btn">Cancel</button>
    </div>
  </div>
</div>

