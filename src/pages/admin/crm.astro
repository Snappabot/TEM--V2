        <div class="pipe-stage" data-status="identified"><span class="count" id="pipe-identified">—</span>Identified</div>
        <div class="pipe-stage" data-status="emailed"><span class="count" id="pipe-emailed">—</span>Emailed</div>
        <div class="pipe-stage" data-status="responded"><span class="count" id="pipe-responded">—</span>Responded</div>
        <div class="pipe-stage" data-status="meeting_booked"><span class="count" id="pipe-meeting_booked">—</span>Meeting</div>
        <div class="pipe-stage" data-status="client"><span class="count" id="pipe-client">—</span>Client</div>
      </div>

      <div class="filters">
        <select class="filter-select" id="filter-state">
