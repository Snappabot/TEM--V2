---
/*
  SQL MIGRATION — run in Supabase SQL editor before using this page:

  create table if not exists contacts (
    id uuid default gen_random_uuid() primary key,
    name text not null,
    company text,
    role text,
    state text,
    instagram_handle text,
    website text,
    email text,
    phone text,
    source text,
    finish_affinity text[] default '{}',
    style_tags text[] default '{}',
    tem_used bool default false,
    priority text default 'cold',
    status text default 'identified',
    notes text,
    created_at timestamptz default now(),
    last_contacted date
  );

  create table if not exists outreach_emails (
    id uuid default gen_random_uuid() primary key,
    contact_id uuid references contacts(id) on delete cascade,
    campaign_name text,
    email_subject text,
    sent_date date,
    opened bool default false,
    replied bool default false,
    reply_date date,
    outcome text,
    follow_up_date date,
    notes text,
    created_at timestamptz default now()
  );

  create table if not exists tem_clients (
    id uuid default gen_random_uuid() primary key,
    contact_id uuid references contacts(id) on delete set null,
    name text not null,
    company text,
    role text,
    project_name text,
    project_location text,
    finishes_used text[] default '{}',
    project_date date,
    instagram_handle text,
    website text,
    portfolio_images text[] default '{}',
    notes text,
    created_at timestamptz default now()
  );
*/
export const prerender = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CRM | TEM Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0a0a0a; color: #e5e5e5; font-family: Inter, system-ui, sans-serif; min-height: 100vh; }
    a { color: #8b7355; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .gate { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .gate-box { width: 100%; max-width: 380px; padding: 2rem; }
    .gate-box h1 { font-weight: 300; font-size: 1.75rem; margin-bottom: 1.5rem; text-align: center; }
    .gate-box input { width: 100%; padding: 0.875rem 1rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px; color: #fff; font-size: 1rem; margin-bottom: 0.75rem; outline: none; }
    .gate-box input:focus { border-color: #8b7355; }
    .gate-box button { width: 100%; padding: 0.875rem; background: #8b7355; color: #fff; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer; }
    .gate-box button:hover { background: #a08060; }
    .error-msg { color: #f87171; font-size: 0.85rem; margin-bottom: 0.75rem; }

    .header { padding: 1.25rem 2rem; border-bottom: 1px solid #1e1e1e; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .header h1 { font-weight: 300; font-size: 1.25rem; }
    .nav-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .nav-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: #555; }
    .nav-links { display: flex; gap: 0.375rem; flex-wrap: wrap; }
    .nav-link { padding: 0.25rem 0.625rem; background: #141414; border: 1px solid #2a2a2a; border-radius: 4px; color: #888; font-size: 0.75rem; text-decoration: none; transition: all 0.15s; }
    .nav-link:hover, .nav-link.active { border-color: #8b7355; color: #e5e5e5; text-decoration: none; }
    .nav-header { display: flex; align-items: flex-start; gap: 1.5rem; flex-wrap: wrap; }
    .logout-btn { background: none; border: none; color: #666; cursor: pointer; font-size: 0.85rem; padding: 0; }
    .logout-btn:hover { color: #fff; }
    .content { max-width: 1200px; margin: 0 auto; padding: 2rem; }

    .tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; border-bottom: 1px solid #1e1e1e; }
    .tab-btn { padding: 0.75rem 1.25rem; background: none; border: none; color: #666; cursor: pointer; font-size: 0.9rem; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
    .tab-btn:hover { color: #e5e5e5; }
    .tab-btn.active { color: #8b7355; border-bottom-color: #8b7355; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .filters { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; align-items: center; }
    .filter-select { padding: 0.5rem 0.75rem; background: #141414; border: 1px solid #2a2a2a; border-radius: 6px; color: #e5e5e5; font-size: 0.8rem; outline: none; cursor: pointer; }
    .filter-select:focus { border-color: #8b7355; }

    /* Pipeline */
    .pipeline { display: flex; gap: 0; margin-bottom: 1.5rem; overflow-x: auto; }
    .pipe-stage { flex: 1; min-width: 140px; text-align: center; padding: 0.625rem; background: #141414; border: 1px solid #1e1e1e; border-right: none; font-size: 0.75rem; color: #888; cursor: pointer; transition: all 0.15s; }
    .pipe-stage:last-child { border-right: 1px solid #1e1e1e; }
    .pipe-stage.active { background: #1a1a0a; border-color: #8b7355; color: #8b7355; }
    .pipe-stage .count { font-size: 1.1rem; font-weight: 600; color: #e5e5e5; display: block; }

    /* Contact list */
    .contact-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .contact-row { background: #141414; border: 1px solid #1e1e1e; border-radius: 8px; padding: 1rem; cursor: pointer; transition: border-color 0.15s; }
    .contact-row:hover { border-color: #2a2a2a; }
    .contact-row.expanded { border-color: #8b7355; }
    .contact-row-main { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .contact-name { font-weight: 500; font-size: 0.95rem; min-width: 160px; }
    .contact-company { color: #888; font-size: 0.85rem; flex: 1; }
    .contact-row-meta { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .contact-detail { display: none; padding-top: 1rem; border-top: 1px solid #1e1e1e; margin-top: 1rem; }
    .contact-detail.show { display: block; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; }
    .detail-item label { font-size: 0.7rem; color: #666; display: block; margin-bottom: 0.2rem; }
    .detail-item span { font-size: 0.85rem; }

    /* Email history */
    .email-history { margin-top: 1rem; }
    .email-history h4 { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
    .email-item { padding: 0.625rem; background: #1a1a1a; border-radius: 6px; margin-bottom: 0.375rem; font-size: 0.8rem; }
    .email-item-header { display: flex; justify-content: space-between; margin-bottom: 0.25rem; }

    /* Badge */
    .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 500; }
    .badge-hot { background: #3a0a0a; color: #f87171; }
    .badge-warm { background: #2a1a00; color: #fb923c; }
    .badge-cold { background: #1a1a2a; color: #818cf8; }
    .badge-identified { background: #1e1e2e; color: #a78bfa; }
    .badge-emailed { background: #1a2a3a; color: #67e8f9; }
    .badge-responded { background: #1a2a2a; color: #34d399; }
    .badge-meeting_booked { background: #1a3a1a; color: #4ade80; }
    .badge-client { background: #1a3a0a; color: #86efac; }
    .badge-passed { background: #1a1a1a; color: #555; }
    .badge-follow-up { background: #3a1a00; color: #fb923c; border: 1px solid #fb923c; }
    .badge-finish { background: #2a1a1a; color: #fca5a5; }

    /* Alert */
    .alert-banner { background: #2a1a00; border: 1px solid #fb923c; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.85rem; color: #fb923c; }

    /* Buttons */
    .btn-primary { padding: 0.625rem 1.25rem; background: #8b7355; color: #fff; border: none; border-radius: 6px; font-size: 0.85rem; cursor: pointer; }
    .btn-primary:hover { background: #a08060; }
    .btn-secondary { padding: 0.625rem 1.25rem; background: #1a1a1a; color: #aaa; border: 1px solid #2a2a2a; border-radius: 6px; font-size: 0.85rem; cursor: pointer; }
    .btn-secondary:hover { border-color: #8b7355; color: #fff; }
    .btn-sm { padding: 0.3rem 0.625rem; font-size: 0.75rem; border-radius: 4px; border: 1px solid #2a2a2a; background: #1a1a1a; color: #aaa; cursor: pointer; }
    .btn-sm:hover { border-color: #8b7355; color: #fff; }

    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.75rem; }
    .section-header h2 { font-weight: 400; font-size: 1.1rem; }
    .empty { color: #555; text-align: center; padding: 3rem 0; font-size: 0.9rem; }

    /* Form modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .modal { background: #141414; border: 1px solid #2a2a2a; border-radius: 12px; padding: 1.75rem; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; }
    .modal h3 { font-weight: 500; font-size: 1rem; margin-bottom: 1.25rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem; }
    .form-row.single { grid-template-columns: 1fr; }
    .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
    .form-group label { font-size: 0.75rem; color: #888; }
    .form-group input, .form-group select, .form-group textarea { padding: 0.625rem 0.75rem; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #e5e5e5; font-size: 0.85rem; outline: none; font-family: inherit; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #8b7355; }
    .form-group textarea { resize: vertical; min-height: 70px; }
    .form-actions { display: flex; gap: 0.75rem; margin-top: 1rem; }

    /* Portfolio grid */
    .portfolio-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .portfolio-card { background: #141414; border: 1px solid #1e1e1e; border-radius: 10px; padding: 1.25rem; }
    .portfolio-card h3 { font-size: 0.95rem; font-weight: 500; margin-bottom: 0.25rem; }
    .portfolio-card .sub { font-size: 0.8rem; color: #888; margin-bottom: 0.75rem; }

    /* CSV export */
    .export-btn { padding: 0.5rem 1rem; background: #1a1a2a; border: 1px solid #2a2a4a; border-radius: 6px; color: #a78bfa; font-size: 0.8rem; cursor: pointer; }
    .export-btn:hover { background: #2a2a4a; }
  </style>
</head>
<body>

<div id="gate" class="gate">
  <div class="gate-box">
    <h1>Admin Access</h1>
    <input type="password" id="pw-input" placeholder="Admin password" />
