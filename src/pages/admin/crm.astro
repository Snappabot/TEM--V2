    { name: 'Kennedy Nolan', company: 'Kennedy Nolan', role: 'architect', state: 'VIC', instagram_handle: '@kennedynolan', priority: 'hot', status: 'identified' },
    { name: 'Mim Design', company: 'Mim Design', role: 'interior_designer', state: 'VIC', instagram_handle: '@mimdesign', priority: 'hot', status: 'identified' },
    { name: 'Studio Tate', company: 'Studio Tate', role: 'interior_designer', state: 'VIC', instagram_handle: '@studiotate', priority: 'warm', status: 'identified' },
    { name: 'Flack Studio', company: 'Flack Studio', role: 'interior_designer', state: 'VIC', instagram_handle: '@flackstudio', priority: 'hot', status: 'identified' },
    { name: 'Fiona Lynch Studio', company: 'Fiona Lynch Studio', role: 'interior_designer', state: 'VIC', instagram_handle: '@fionalynchoffice', priority: 'warm', status: 'identified' },
    { name: 'Studio Minosa', company: 'Studio Minosa', role: 'interior_designer', state: 'NSW', instagram_handle: '@studiominosa', priority: 'warm', status: 'identified' },
