      </div>
    </div>

    <!-- OUTREACH TAB -->
    <div id="tab-outreach" class="tab-panel">
      <div class="section-header">
        <h2>Cold Email Campaign Tracker</h2>
        <button class="btn-primary" id="log-email-btn">+ Log Email</button>
      </div>
      <div id="outreach-list"><div class="empty">Loading outreach history...</div></div>
