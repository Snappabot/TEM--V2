    <div class="header">
      <h1>TEM Admin — Trends</h1>
      <div class="nav-header">
        <div class="nav-group">
          <span class="nav-label">SEO &amp; Campaigns</span>
          <div class="nav-links">
            <a href="/admin/campaigns" class="nav-link">Campaigns</a>
            <a href="/admin/strategy" class="nav-link">Strategy</a>
            <a href="/admin/content" class="nav-link">Content</a>
