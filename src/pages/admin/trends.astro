        </div>

        <button class="btn-primary toggle-form-btn" id="toggle-add-article">+ Add Article</button>

        <!-- Add Article Form -->
        <div id="add-article-form" class="form-panel" style="display:none">
          <h3>Add Article Manually</h3>
          <div class="form-row">
            <div class="form-group">
              <label>Title *</label>
