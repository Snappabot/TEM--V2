          </div>
        </div>
        <div class="nav-group">
          <span class="nav-label">Intelligence</span>
          <div class="nav-links">
            <a href="/admin/trends" class="nav-link active">Trends</a>
            <a href="/admin/crm" class="nav-link">CRM</a>
            <a href="/admin/portfolio" class="nav-link">Portfolio</a>
