            <div class="form-group">
              <label>Style Tags (comma-separated)</label>
              <input type="text" id="art-styles" placeholder="biophilic, japandi, sustainable" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Opportunity Level</label>
              <select id="art-opportunity">
                <option value="none">None</option>
                <option value="low">Low</option>
                <option value="medium">Medium</option>
