          </div>
        </div>

        <!-- Articles Grid -->
        <div class="card-grid" id="articles-grid">
          <div class="empty">Loading articles...</div>
        </div>
      </div>

      <!-- TAB: Missed Markets -->
      <div id="tab-markets" class="tab-panel">
        <div class="section-header">
          <h2>Missed Market Radar</h2>
          <button class="btn-primary" id="seed-markets-btn">Seed Default Markets</button>
        </div>
        <div class="card-grid" id="markets-grid">
          <div class="empty">Loading markets...</div>
        </div>
      </div>
    </div>
  </div>

<script>
  const ADMIN_PW = 'TEM-admin-2026!';
  const SB_URL = 'https://djtxbohjjpkhzhwlnrtu.supabase.co';
  const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRqdHhib2hqanBraHpod2xucnR1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwNDgzMjEsImV4cCI6MjA4NjYyNDMyMX0.UWgOz-9ZAy0xxVH-VTTysFzvrbD1CX0a459rNC391Hw';

  const MISSED_MARKETS_SEED = [
    { market_name: 'Passive House AU', description: 'Natural breathable renders, hemp lime ideal for certified Passive House builds', finish_types: ['hemp','lime'], estimated_size: 'Growing — ~500 certified builds/yr', competition_level: 'low', opportunity_score: 9, research_notes: 'PHAA members directory is a goldmine for outreach', status: 'identified' },
    { market_name: 'Mudbrick/Rammed Earth Heritage Restorers', description: 'Lime compatibility critical — these builders need heritage-appropriate finishes', finish_types: ['lime','clay'], estimated_size: 'Niche but premium', competition_level: 'low', opportunity_score: 9, research_notes: 'Earth Builders Association + Council heritage grants', status: 'identified' },
    { market_name: 'Luxury Hotel Refits (Boutique)', description: 'Bespoke finishes as point of difference — high spend, repeat work', finish_types: ['venetian','microcement','tadelakt'], estimated_size: 'High value per project', competition_level: 'medium', opportunity_score: 9, research_notes: 'Target boutique hotel groups in VIC/NSW', status: 'identified' },
    { market_name: 'Wellness Centres & Day Spas', description: 'Biophilic interior finishes — earth tones, texture, humidity-tolerant', finish_types: ['venetian','clay','lime'], estimated_size: 'Medium — growing sector', competition_level: 'medium', opportunity_score: 7, research_notes: 'Instagram hashtag #spaaesthetic shows demand', status: 'identified' },
    { market_name: 'Education Sector (Montessori/Waldorf)', description: 'Natural materials mandate — parents and schools pay premium for authentic', finish_types: ['clay','hemp','lime'], estimated_size: 'Niche but loyal', competition_level: 'low', opportunity_score: 7, research_notes: 'Waldorf Australia & Montessori Australia directories', status: 'identified' },
    { market_name: 'Wine Cellar & Barrel Room Fitouts', description: 'Lime render for humidity control — functional AND aesthetic angle', finish_types: ['lime'], estimated_size: 'Small but very premium', competition_level: 'low', opportunity_score: 7, research_notes: 'Yarra Valley / Mornington Peninsula wineries', status: 'identified' },
    { market_name: 'High-end Food & Beverage (Restaurants)', description: 'Textured accent walls — designers spec finishes for atmosphere', finish_types: ['venetian','microcement','clay'], estimated_size: 'Large in metro areas', competition_level: 'high', opportunity_score: 8, research_notes: 'Target interior designers who spec restaurant fitouts', status: 'identified' },
    { market_name: 'Film/TV Set Design', description: 'Decorative plaster demand for period shoots and bespoke sets', finish_types: ['venetian','lime','clay'], estimated_size: 'Melbourne film scene growing', competition_level: 'low', opportunity_score: 5, research_notes: 'Screen Australia, AFTRS, VIC production companies', status: 'identified' },
    { market_name: 'Display Homes (Volume Builders)', description: 'Premium finish showcase to upsell buyers — recurring large contracts', finish_types: ['venetian','microcement'], estimated_size: 'Very large', competition_level: 'high', opportunity_score: 6, research_notes: 'Metricon, Simonds, AV Jennings display villages', status: 'identified' },
    { market_name: 'Tiny Home / Modular Builds', description: 'Lightweight hemp render — growing movement with sustainability focus', finish_types: ['hemp'], estimated_size: 'Small but growing fast', competition_level: 'low', opportunity_score: 6, research_notes: 'Tiny Houses Australia community', status: 'identified' },
  ];

  function sbHeaders() {
    return { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' };
  }

  async function sbGet(table: string, query = '') {
    const r = await fetch(`${SB_URL}/rest/v1/${table}?${query}`, { headers: sbHeaders() });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }

  async function sbInsert(table: string, data: any) {
    const r = await fetch(`${SB_URL}/rest/v1/${table}`, { method: 'POST', headers: sbHeaders(), body: JSON.stringify(data) });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }

  async function sbPatch(table: string, id: string, data: any) {
    const r = await fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'PATCH', headers: sbHeaders(), body: JSON.stringify(data) });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }

  function opBadge(level: string) {
    const map: any = { high: 'badge-high', medium: 'badge-medium', low: 'badge-low', none: 'badge-none' };
    return `<span class="badge ${map[level] || 'badge-none'}">${level || 'none'}</span>`;
  }

  function statusBadge(s: string) {
    const map: any = { identified: 'badge-identified', researching: 'badge-researching', actioned: 'badge-actioned', passed: 'badge-passed' };
    return `<span class="badge ${map[s] || 'badge-identified'}">${s || 'identified'}</span>`;
  }

  let allArticles: any[] = [];

  async function loadArticles() {
    const grid = document.getElementById('articles-grid')!;
    const note = document.getElementById('synced-note')!;
    try {
      allArticles = await sbGet('trend_articles', 'order=created_at.desc');
      note.textContent = `Last synced: ${new Date().toLocaleTimeString('en-AU')}`;
      renderArticles();
    } catch(e) {
      grid.innerHTML = `<div class="empty">Error loading articles. Check Supabase table exists.</div>`;
    }
  }

  function renderArticles() {
    const grid = document.getElementById('articles-grid')!;
    const src = (document.getElementById('filter-source') as HTMLSelectElement).value;
    const opp = (document.getElementById('filter-opportunity') as HTMLSelectElement).value;
    const act = (document.getElementById('filter-actioned') as HTMLSelectElement).value;

    let arts = allArticles;
    if (src) arts = arts.filter(a => a.source === src);
    if (opp) arts = arts.filter(a => a.opportunity_level === opp);
    if (act !== '') arts = arts.filter(a => String(a.actioned) === act);

    if (!arts.length) { grid.innerHTML = '<div class="empty">No articles found. Add one above.</div>'; return; }

    grid.innerHTML = arts.map(a => `
      <div class="card" id="article-${a.id}">
        <div class="card-title">${a.title}</div>
        <div class="card-meta">${a.published_date || ''} ${a.published_date ? '·' : ''} ${a.source?.replace(/_/g,' ')}</div>
        <div class="tags-row">
          ${opBadge(a.opportunity_level)}
          <span class="badge badge-source">${a.source?.replace(/_/g,' ')}</span>
          ${(a.finish_types||[]).map((f:string)=>`<span class="badge badge-finish">${f}</span>`).join('')}
          ${(a.style_tags||[]).map((s:string)=>`<span class="badge badge-style">${s}</span>`).join('')}
          ${a.actioned ? '<span class="badge badge-actioned">Actioned</span>' : ''}
        </div>
        ${a.opportunity_notes ? `<div class="card-notes">${a.opportunity_notes}</div>` : ''}
        ${a.contact_name ? `<div class="card-notes" style="margin-top:0.25rem">Contact: ${a.contact_name}</div>` : ''}
        <div style="display:flex;gap:0.5rem;margin-top:0.75rem;flex-wrap:wrap;align-items:center">
          ${a.url ? `<a href="${a.url}" target="_blank" style="font-size:0.78rem">View article →</a>` : ''}
          ${!a.actioned ? `<button class="btn-sm btn-actioned action-btn" data-id="${a.id}">Mark Actioned</button>` : ''}
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.action-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id!;
        await sbPatch('trend_articles', id, { actioned: true, last_updated: new Date().toISOString() });
        loadArticles();
      });
    });
  }

  async function loadMarkets() {
    const grid = document.getElementById('markets-grid')!;
    try {
      const markets = await sbGet('missed_markets', 'order=opportunity_score.desc');
      if (!markets.length) { grid.innerHTML = '<div class="empty">No markets yet. Click "Seed Default Markets" to pre-populate.</div>'; return; }
      renderMarkets(markets);
    } catch(e) {
      grid.innerHTML = `<div class="empty">Error loading markets. Check Supabase table exists.</div>`;
    }
  }

  function renderMarkets(markets: any[]) {
    const grid = document.getElementById('markets-grid')!;
    const statusOptions = ['identified','researching','actioned','passed'];
    grid.innerHTML = markets.map(m => `
      <div class="card">
        <div class="card-title">${m.market_name}</div>
        <div class="score-bar-wrap">
          <div class="score-bar-label"><span>Opportunity</span><span>${m.opportunity_score}/10</span></div>
          <div class="score-bar"><div class="score-fill" style="width:${m.opportunity_score*10}%"></div></div>
        </div>
        <div class="market-meta">
          <span>Competition: ${m.competition_level || 'medium'}</span>
          ${m.estimated_size ? `<span>${m.estimated_size}</span>` : ''}
        </div>
        <div class="tags-row">
          ${statusBadge(m.status)}
          ${(m.finish_types||[]).map((f:string)=>`<span class="badge badge-finish">${f}</span>`).join('')}
        </div>
        <div class="card-meta" style="margin-bottom:0.5rem">${m.description || ''}</div>
        ${m.research_notes ? `<div class="card-notes">${m.research_notes}</div>` : ''}
        <div style="margin-top:0.75rem">
          <select class="filter-select market-status-select" data-id="${m.id}" style="font-size:0.75rem;padding:0.25rem 0.5rem">
            ${statusOptions.map(s=>`<option value="${s}" ${m.status===s?'selected':''}>${s}</option>`).join('')}
          </select>
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.market-status-select').forEach(sel => {
      sel.addEventListener('change', async (e) => {
        const el = e.currentTarget as HTMLSelectElement;
        await sbPatch('missed_markets', el.dataset.id!, { status: el.value });
      });
    });
  }

  // Init
  const gate = document.getElementById('gate')!;
  const app = document.getElementById('app')!;
  const pwInput = document.getElementById('pw-input') as HTMLInputElement;
  const pwBtn = document.getElementById('pw-btn')!;
  const pwError = document.getElementById('pw-error')!;

  function tryLogin(pw: string) {
    if (pw === ADMIN_PW) {
      sessionStorage.setItem('tem-admin-password', pw);
      gate.style.display = 'none';
      app.style.display = 'block';
      loadArticles();
      loadMarkets();
    } else {
      pwError.textContent = 'Invalid password';
      pwError.style.display = 'block';
    }
  }

  if (sessionStorage.getItem('tem-admin-password') === ADMIN_PW) {
    gate.style.display = 'none';
    app.style.display = 'block';
    loadArticles();
    loadMarkets();
  }

  pwBtn.addEventListener('click', () => tryLogin(pwInput.value));
  pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(pwInput.value); });

  document.getElementById('logout-btn')!.addEventListener('click', () => {
    sessionStorage.removeItem('tem-admin-password');
    gate.style.display = 'flex';
    app.style.display = 'none';
  });

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const tab = (e.currentTarget as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      document.getElementById(`tab-${tab}`)!.classList.add('active');
    });
  });

  // Filters
  ['filter-source','filter-opportunity','filter-actioned'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderArticles);
  });

  document.getElementById('refresh-articles-btn')!.addEventListener('click', loadArticles);

  // Add article toggle
  const toggleBtn = document.getElementById('toggle-add-article')!;
  const addForm = document.getElementById('add-article-form')!;
  toggleBtn.addEventListener('click', () => {
    addForm.style.display = addForm.style.display === 'none' ? 'block' : 'none';
    toggleBtn.textContent = addForm.style.display === 'none' ? '+ Add Article' : '— Cancel';
  });
  document.getElementById('cancel-article-btn')!.addEventListener('click', () => {
    addForm.style.display = 'none';
    toggleBtn.textContent = '+ Add Article';
  });

  document.getElementById('save-article-btn')!.addEventListener('click', async () => {
    const title = (document.getElementById('art-title') as HTMLInputElement).value.trim();
    if (!title) { alert('Title is required'); return; }
    const finishes = (document.getElementById('art-finishes') as HTMLInputElement).value.split(',').map(s=>s.trim()).filter(Boolean);
    const styles = (document.getElementById('art-styles') as HTMLInputElement).value.split(',').map(s=>s.trim()).filter(Boolean);
    await sbInsert('trend_articles', {
      title,
      source: (document.getElementById('art-source') as HTMLSelectElement).value,
      url: (document.getElementById('art-url') as HTMLInputElement).value || null,
      published_date: (document.getElementById('art-date') as HTMLInputElement).value || null,
      finish_types: finishes,
      style_tags: styles,
      opportunity_level: (document.getElementById('art-opportunity') as HTMLSelectElement).value,
      opportunity_notes: (document.getElementById('art-notes') as HTMLTextAreaElement).value || null,
      contact_name: (document.getElementById('art-contact-name') as HTMLInputElement).value || null,
    });
    addForm.style.display = 'none';
    toggleBtn.textContent = '+ Add Article';
    loadArticles();
  });

  // Seed markets
  document.getElementById('seed-markets-btn')!.addEventListener('click', async () => {
    if (!confirm('This will seed the 10 default missed markets. Continue?')) return;
    for (const m of MISSED_MARKETS_SEED) await sbInsert('missed_markets', m);
    loadMarkets();
  });
</script>
</body>
</html>
