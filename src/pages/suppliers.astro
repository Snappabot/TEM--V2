---
import Layout from '../layouts/Layout.astro';
import AnimatedFooter from '../components/AnimatedFooter';

const suppliers = [
  {
    name: 'Render Supply Co',
    description: 'Australia\'s premier supplier of rendering and plastering materials. Full Troweled Earth range available online with Australia-wide shipping.',
    logo: 'https://store.rendersupplyco.com.au/media/logo/websites/1/Final-Logo.png',
    logoAlt: 'Render Supply Co',
    href: 'https://store.rendersupplyco.com.au/interior-and-exterior-coatings/surface-coating/troweled-earth.html',
    cta: 'Shop Our Range',
    bg: '#ffffff',
  },
  {
    name: 'Colour World Geelong',
    description: 'Geelong\'s specialist paint and decorative finishes store. Visit in-store to see and feel the Troweled Earth range first-hand.',
    logo: 'https://colourworld.com.au/cdn/shop/files/logo-footer.png?v=1771419160',
    logoAlt: 'Colour World Geelong',
    href: 'https://colourworld.com.au/',
    cta: 'Visit Website',
    bg: '#ffffff',
  },
  {
    name: 'Wet Trades',
    description: 'Specialist supplier for the plastering and rendering trade. Stocking Troweled Earth products for professionals and applicators.',
    logo: 'https://wettrades.com.au/wp-content/uploads/2023/09/wettrades-logo-Wordpress-ai-2-1024x375-1-1-150x141.png',
    logoAlt: 'Wet Trades',
    href: 'https://wettrades.com.au/',
    cta: 'Visit Website',
    bg: '#ffffff',
  },
  {
    name: 'Metro Build Suppliers',
    description: 'Melbourne-based building supplies specialist. Troweled Earth products available for trade and retail customers.',
    logo: null,
    logoAlt: 'Metro Build Suppliers',
    href: 'https://metrobuildsuppliers.com.au/',
    cta: 'Visit Website',
    bg: '#ffffff',
  },
];
---

<Layout title="Where to Buy | Troweled Earth Melbourne">

  <!-- Hero -->
  <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center bg-[#0a0a0a] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0a0a0a]/80 z-10"></div>
    <div class="relative z-20 text-center px-6">
      <span class="text-[#8b7355] text-sm uppercase tracking-[0.3em] mb-4 block">Authorised Stockists</span>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white tracking-tight">Where to Buy</h1>
      <p class="text-white/50 mt-6 max-w-xl mx-auto text-base">Our premium plaster finishes are available through these authorised stockists across Australia.</p>
    </div>
  </section>

  <!-- Suppliers Grid -->
  <section class="py-24 bg-[#f5f5f0]">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-6">
        {suppliers.map(supplier => (
          <a
            href={supplier.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden flex flex-col"
          >
            {/* Logo area */}
            <div class="flex items-center justify-center h-32 px-8 border-b border-[#1a1a1a]/8 bg-white">
              {supplier.logo ? (
                <img
                  src={supplier.logo}
                  alt={supplier.logoAlt}
                  class="max-h-16 max-w-[200px] w-auto object-contain"
                />
              ) : (
                <span class="text-xl font-bold text-[#1a1a1a] tracking-tight">{supplier.name}</span>
              )}
            </div>

            {/* Content */}
            <div class="p-8 flex flex-col flex-1">
              <h2 class="text-lg font-bold text-[#1a1a1a] mb-3">{supplier.name}</h2>
              <p class="text-[#1a1a1a]/60 text-sm leading-relaxed mb-6 flex-1">{supplier.description}</p>
              <div class="inline-flex items-center gap-2 text-xs uppercase tracking-widest font-medium text-[#8b7355] group-hover:text-[#1a1a1a] transition-colors">
                {supplier.cta}
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Need Help Choosing?</h2>
      <p class="text-xl text-white/60 mb-8">Our team can guide you to the perfect finish for your project.</p>
      <a href="/#contact" class="inline-flex items-center gap-3 px-8 py-4 bg-[#8b7355] text-white font-medium uppercase tracking-widest text-sm hover:bg-[#a68b6a] transition-colors">
        Contact Us
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <AnimatedFooter client:visible />
</Layout>
