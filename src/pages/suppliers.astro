---
import Layout from '../layouts/Layout.astro';
import AnimatedFooter from '../components/AnimatedFooter';
---

<Layout title="Where to Buy | Troweled Earth Melbourne">

  <!-- Hero Section -->
  <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center bg-[#0a0a0a] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0a0a0a]/80 z-10"></div>
    <div class="relative z-20 text-center px-6">
      <span class="text-[#8b7355] text-sm uppercase tracking-[0.3em] mb-4 block">Authorised Stockists</span>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white tracking-tight">
        Where to Buy
      </h1>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-24 bg-[#f5f5f0]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      
      <!-- Intro -->
      <div class="mb-16">
        <p class="text-2xl md:text-3xl text-[#1a1a1a] leading-relaxed font-light mb-8">
          Ready to transform your space with Troweled Earth products?
        </p>
        <p class="text-lg text-[#1a1a1a]/70 leading-relaxed max-w-2xl mx-auto">
          Our premium plaster finishes are available through our authorised stockists.
          Browse online or visit in-store.
        </p>
      </div>

      <!-- Supplier Cards -->
      <div class="grid md:grid-cols-3 gap-8 mb-16">

        <!-- Render Supply Co -->
        <div class="bg-white rounded-lg shadow-lg p-10 flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-[#8b7355]/10 rounded-full flex items-center justify-center mb-5">
            <svg class="w-8 h-8 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-[#1a1a1a] mb-3">Render Supply Co</h2>
          <p class="text-[#1a1a1a]/70 mb-6 text-sm leading-relaxed">
            Australia's premier supplier of rendering and plastering materials.
            Full Troweled Earth range available online with Australia-wide shipping.
          </p>
          <a
            href="https://store.rendersupplyco.com.au/interior-and-exterior-coatings/surface-coating/troweled-earth.html"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-4 bg-[#1a1a1a] text-white font-medium uppercase tracking-widest text-xs hover:bg-[#8b7355] transition-colors mt-auto"
          >
            Shop Online
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Colour World Geelong -->
        <div class="bg-white rounded-lg shadow-lg p-10 flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-[#8b7355]/10 rounded-full flex items-center justify-center mb-5">
            <svg class="w-8 h-8 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-[#1a1a1a] mb-3">Colour World Geelong</h2>
          <p class="text-[#1a1a1a]/70 mb-6 text-sm leading-relaxed">
            Geelong's specialist paint and decorative finishes store.
            Visit in-store to see and feel the Troweled Earth range first-hand.
          </p>
          <a
            href="https://colourworld.com.au/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-4 bg-[#1a1a1a] text-white font-medium uppercase tracking-widest text-xs hover:bg-[#8b7355] transition-colors mt-auto"
          >
            Visit Website
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Wet Trades -->
        <div class="bg-white rounded-lg shadow-lg p-10 flex flex-col items-center text-center ">
          <div class="w-16 h-16 bg-[#8b7355]/10 rounded-full flex items-center justify-center mb-5">
            <svg class="w-8 h-8 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-[#1a1a1a] mb-3">Wet Trades</h2>
          <p class="text-[#1a1a1a]/70 mb-6 text-sm leading-relaxed">
            Specialist supplier for the plastering and rendering trade.
            Stocking Troweled Earth products for professionals and applicators.
          </p>
          <a
            href="https://wettrades.com.au/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-4 bg-[#1a1a1a] text-white font-medium uppercase tracking-widest text-xs hover:bg-[#8b7355] transition-colors mt-auto"
          >
            Visit Website
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Additional Info -->
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-[#8b7355]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#1a1a1a] mb-2">Full Range</h3>
          <p class="text-[#1a1a1a]/60 text-sm">All Troweled Earth products in stock</p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-[#8b7355]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#1a1a1a] mb-2">Fast Delivery</h3>
          <p class="text-[#1a1a1a]/60 text-sm">Australia-wide shipping available</p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-[#8b7355]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#8b7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#1a1a1a] mb-2">Expert Support</h3>
          <p class="text-[#1a1a1a]/60 text-sm">Technical advice when you need it</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Need Help Choosing?</h2>
      <p class="text-xl text-white/60 mb-8">Our team can guide you to the perfect finish for your project.</p>
      <a 
        href="/#contact" 
        class="inline-flex items-center gap-3 px-8 py-4 bg-[#8b7355] text-white font-medium uppercase tracking-widest text-sm hover:bg-[#a68b6a] transition-colors"
      >
        Contact Us
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <AnimatedFooter client:visible />
</Layout>
