---
import Layout from '../layouts/Layout.astro';
import CustomCursor from '../components/CustomCursor';
import ScrollProgress from '../components/ScrollProgress';
import AnimatedFooter from '../components/AnimatedFooter';

const projects = [
  {
    title: 'Proclamation House',
    architect: 'State of Kin',
    location: 'Subiaco, Western Australia',
    finish: 'Earthen Hemp Render',
    image: 'https://static.dezeen.com/uploads/2024/08/proclamation-house-state-of-kin-architecture-residential-australia-hemp-render_dezeen_1704_hero.jpg',
    summary: 'Architecture studio State of Kin paired an olive-toned hemp render with aluminium awnings at this light-filled family home. The hemp render provides a distinctive, earthy look that complements the natural, organic feel — seamlessly integrating with the home\'s surrounding environment while offering superior insulation and acoustic performance.',
    award: 'Featured in Dezeen',
    link: 'https://www.dezeen.com/2024/08/14/state-of-kin-proclamation-house-hemp/',
    linkLabel: 'Read on Dezeen →',
  },
  {
    title: 'Enclosed House II',
    architect: 'MORQ Architecture',
    location: 'Western Australia',
    finish: 'Marbellino',
    image: 'https://d31dpzy4bseog7.cloudfront.net/media/2023/10/06122646/MORQ-Thumbnails-15-1024x576.png',
    summary: 'MORQ Architecture\'s Enclosed House II is a study in spatial restraint and material depth. The polished plaster finish wraps interior walls in a continuous, seamless surface — blurring the boundary between architecture and texture. Featured by The Local Project for its cinematic interior atmosphere.',
    award: 'The Local Project Feature',
    link: 'https://thelocalproject.com.au/videos/enclosed-house-ii-by-morq-video-feature-the-local-project/',
    linkLabel: 'View on The Local Project →',
  },
  {
    title: 'City Beach House',
    architect: 'MORQ Architecture',
    location: 'City Beach, Western Australia',
    finish: 'Marbellino',
    image: 'https://www.architecture.com.au/wp-content/uploads/00_9097-resaltsadds_City-Beach-House_MORQ-Architecture_GivlioAristide-1.jpg',
    summary: 'Recognised by the Australian Institute of Architects, City Beach House by MORQ demonstrates how artisan plaster finishes can define an entire architectural identity. Curved volumes and refined surfaces create a home that is simultaneously bold and intimate — a benchmark in contemporary Australian residential design.',
    award: 'AIA Award — Architecture Australia',
    link: 'https://www.architecture.com.au/archives/awards/city-beach-house-morq-architecture',
    linkLabel: 'View AIA Award →',
  },
  {
    title: 'Park House',
    architect: 'MORQ Architects',
    location: 'Western Australia',
    finish: 'Concretum',
    image: 'https://d-vsl.com/wp-content/uploads/2020/07/Park-House-in-Australia-designed-by-Morq-6.jpg',
    summary: 'Park House by MORQ Architects is a masterclass in raw material beauty. The Concretum finish — a hand-applied concrete plaster — gives the home\'s walls an industrial depth that softens beautifully in natural light. Featured on d-vsl for its considered material palette and spatial generosity.',
    award: 'Featured on d-vsl',
    link: 'https://d-vsl.com/architecture/park-house-morq-architects/',
    linkLabel: 'View on d-vsl →',
  },
  {
    title: '849 Mandurah Residence',
    architect: 'Giorgi',
    location: 'Mandurah, Western Australia',
    finish: 'Marbellino',
    image: 'https://d31dpzy4bseog7.cloudfront.net/media/2023/07/12220656/849-Mandurah-Residence-by-Giorgi-Project-Feature-The-Local-Project-Image-15-1024x683.jpg',
    summary: 'The 849 Mandurah Residence by Giorgi is defined by its sculptural curves and the warm depth of its polished Marbellino finish. Sweeping walls and soaring ceilings in an uninterrupted plaster surface create a home of genuine emotional impact — featured by The Local Project as an exemplar of West Australian luxury residential design.',
    award: 'The Local Project Feature',
    link: 'https://thelocalproject.com.au/articles/849-mandurah-residence-by-giorgi-project-feature-the-local-project/',
    linkLabel: 'View on The Local Project →',
  },
  {
    title: 'Walsh Residence',
    architect: 'Giorgi',
    location: 'Western Australia',
    finish: 'Marbellino',
    image: 'https://www.architecture.com.au/wp-content/uploads/00_7666_Walsh-Residence_Giorgi_Alex-Reinders.jpg',
    summary: 'The Walsh Residence by Giorgi earned recognition from the Australian Institute of Architects for its exceptional material quality and spatial composition. The polished plaster finish — seamless from interior to exterior — reflects the ambition of both the architect and the client: a home that is genuinely, undeniably singular.',
    award: 'AIA Award — Architecture Australia',
    link: 'https://www.architecture.com.au/archives/awards/walsh-residence-giorgi',
    linkLabel: 'View AIA Award →',
  },
];
---

<Layout title="Projects | Troweled Earth Melbourne">
  <CustomCursor client:load />
  <ScrollProgress client:load />

  <!-- Hero -->
  <section class="relative h-[55vh] min-h-[420px] flex items-end bg-[#0a0a0a] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/50 to-[#0a0a0a]" />
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-14 w-full">
      <span class="text-[#8b7355] text-xs uppercase tracking-[0.5em] block mb-5">Award-Winning Work</span>
      <h1 class="text-6xl md:text-8xl font-bold text-white tracking-tight leading-none">Projects</h1>
      <p class="text-white/50 mt-5 max-w-xl text-base leading-relaxed">
        Our finishes have been featured in internationally recognised homes and architectural publications — designed by Australia's most respected studios.
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section class="bg-[#0a0a0a] py-8">
    <div class="max-w-7xl mx-auto px-6">
      <div class="space-y-0">
        {projects.map((project, i) => (
          <article class={`grid md:grid-cols-2 gap-0 ${i % 2 === 1 ? 'md:grid-flow-dense' : ''} border-b border-white/8`}>

            {/* Image */}
            <div class={`relative overflow-hidden aspect-[4/3] ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent" />
              {/* Award badge */}
              <div class="absolute top-5 left-5">
                <span class="text-[10px] uppercase tracking-[0.3em] text-white/70 bg-black/50 px-3 py-1.5 backdrop-blur-sm">
                  {project.award}
                </span>
              </div>
            </div>

            {/* Content */}
            <div class={`flex flex-col justify-center p-10 md:p-14 lg:p-20 bg-[#0d0d0d] ${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
              <div class="flex items-center gap-3 mb-6">
                <div class="w-5 h-px bg-[#8b7355]" />
                <span class="text-[#8b7355] text-xs uppercase tracking-[0.4em]">{project.finish}</span>
              </div>

              <h2 class="text-white text-3xl md:text-4xl font-bold mb-2 leading-tight">{project.title}</h2>
              <p class="text-white/40 text-sm mb-6">{project.architect} — {project.location}</p>

              <p class="text-white/60 leading-relaxed text-sm mb-8 max-w-md">{project.summary}</p>

              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3 text-white self-start"
              >
                <span class="text-xs uppercase tracking-[0.35em] border-b border-[#8b7355] pb-0.5 group-hover:border-white transition-colors">
                  {project.linkLabel}
                </span>
                <svg class="w-3.5 h-3.5 text-[#8b7355] group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Your Project Could Be Next</h2>
      <p class="text-xl text-white/50 mb-8 max-w-2xl mx-auto">Talk to Matt about what's possible for your space.</p>
      <a href="/#contact" class="inline-flex items-center gap-3 px-8 py-4 bg-[#8b7355] text-white font-medium uppercase tracking-widest text-sm hover:bg-[#a68b6a] transition-colors">
        Get in Touch
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <AnimatedFooter client:visible />
</Layout>
