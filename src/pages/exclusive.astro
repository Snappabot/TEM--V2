---
import ExclusiveForm from '../components/ExclusiveForm';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exclusive Commission — Troweled Earth Melbourne</title>
  <meta name="description" content="Apply for an exclusive bespoke commission with Troweled Earth Melbourne. We accept a limited number of exclusive commissions each year." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #0a0a0a; color: white; font-family: 'Inter', sans-serif; }
    body { overflow-x: hidden; }

    @keyframes kenBurns {
      0%   { transform: scale(1.0) translate(0%, 0%); }
      50%  { transform: scale(1.08) translate(-1.5%, -1%); }
      100% { transform: scale(1.04) translate(1%, 0.5%); }
    }
    .ken-burns {
      animation: kenBurns 20s ease-in-out infinite alternate;
      will-change: transform;
    }

    @keyframes chevronBounce {
      0%, 100% { transform: translateY(0); opacity: 0.5; }
      50%       { transform: translateY(8px); opacity: 1; }
    }
    .chevron-bounce {
      animation: chevronBounce 2.2s ease-in-out infinite;
    }
  </style>
</head>
<body>

  <!-- Back arrow -->
  <a
    href="/"
    style="
      position: fixed;
      top: 2rem;
      left: 2rem;
      z-index: 50;
      color: rgba(255,255,255,0.45);
      font-family: 'Inter', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: color 0.2s;
    "
    onmouseover="this.style.color='rgba(255,255,255,0.8)'"
    onmouseout="this.style.color='rgba(255,255,255,0.45)'"
  >
    ← Troweled Earth
  </a>

  <!-- Hero -->
  <section
    style="
      position: relative;
      width: 100%;
      height: 100dvh;
      min-height: 600px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      text-align: center;
    "
  >
    <!-- Background image with Ken Burns -->
    <div
      style="
        position: absolute;
        inset: -6%;
        z-index: 0;
      "
    >
      <img
        src="/images/products/custom-finishes/Custom+finish+2.png"
        alt=""
        aria-hidden="true"
        class="ken-burns"
        style="
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
          filter: brightness(0.2);
          display: block;
        "
      />
    </div>

    <!-- Gradient overlays -->
    <div style="position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom, rgba(10,10,10,0.3) 0%, transparent 40%, transparent 60%, rgba(10,10,10,0.9) 100%);" />

    <!-- Content -->
    <div style="position:relative;z-index:2;padding:0 1.5rem;max-width:700px;margin:0 auto;">
      <p
        style="
          font-family: 'Inter', sans-serif;
          font-size: 0.65rem;
          letter-spacing: 0.3em;
          text-transform: uppercase;
          color: #8b7355;
          margin-bottom: 2rem;
        "
      >
        By Invitation
      </p>

      <h1
        style="
          font-family: 'Cormorant Garamond', serif;
          font-size: clamp(3.5rem, 9vw, 7rem);
          font-weight: 500;
          line-height: 1.05;
          color: white;
          margin-bottom: 2rem;
          letter-spacing: -0.01em;
        "
      >
        Begin Your<br />Exclusive Commission
      </h1>

      <p
        style="
          font-family: 'Inter', sans-serif;
          font-size: clamp(0.875rem, 2vw, 1rem);
          line-height: 1.7;
          color: rgba(255,255,255,0.5);
          max-width: 38ch;
          margin: 0 auto;
        "
      >
        We accept a limited number of exclusive commissions each year. Before we begin, we would like to understand your vision.
      </p>
    </div>

    <!-- Scroll indicator -->
    <div
      style="
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      "
    >
      <a href="#application" style="display:block;color:rgba(255,255,255,0.35);">
        <svg class="chevron-bounce" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Application Form -->
  <ExclusiveForm client:load />

  <!-- Bottom mark -->
  <div
    style="
      background: #0a0a0a;
      padding: 3rem 1.5rem;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.04);
    "
  >
    <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.15);">
      Troweled Earth Melbourne — All applications are reviewed personally
    </p>
  </div>

</body>
</html>
